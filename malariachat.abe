// /v1/first-line — read-only metadata endpoint. Returns the RBC-2024
// first-line antimalarial currently assigned to the patient's
// district. Resolution: district → mft_group (A/B/C from the MFT
// Q&A page 3 grouping) → drug (from mft_current_drug, which rotates
// yearly per the Q&A and must be updated against the latest RBC
// bulletin). Per MFT Q&A page 9, CHWs are authorised to dose
// whichever drug their group has — no "out of scope" redirect needed.
function doFirstLine(country: string, district: string, lang: string, auditId: string): string {
    const db = dbConnect("dbname=malariachat");
    let districtName: string = "";
    let province:     string = "";
    let mftGroup:     string = "";
    let mftCtxSource: string = "";

    if (district.length() > 0) {
        // Resolve the user-supplied district. Unknown → 400.
        const rD = dbQuery(db,
            "SELECT name, province, mft_group FROM districts ORDER BY name");
        const nD: i64 = dbResultRowCount(rD);
        const districtLower = district.toLowerCase();
        for (let i: i64 = 0; i < nD; i = i + 1) {
            const nm: string = dbResultGet(rD, i, 0);
            if (nm.toLowerCase() == districtLower) {
                districtName = nm;
                province     = dbResultGet(rD, i, 1);
                mftGroup     = dbResultGet(rD, i, 2);
                break;
            }
        }
        if (districtName.length() == 0) {
            dbDisconnect(db);
            return "400{"
                 + "\"task\":\"first-line\","
                 + "\"error\":\"Unknown district '" + jsonEscape(district) + "'. Rwanda has 30 districts; check spelling.\","
                 + "\"auditId\":\"" + auditId + "\""
                 + "}";
        }
        mftCtxSource = "user-supplied-district";
    } else {
        // No district supplied → default to Group A.
        mftGroup     = "A";
        mftCtxSource = "default-group-a";
    }

    const rG = dbQuery(db,
        "SELECT group_letter, drug, source_note FROM mft_current_drug");
    const nG: i64 = dbResultRowCount(rG);
    let drug:       string = "";
    let sourceNote: string = "";
    for (let i: i64 = 0; i < nG; i = i + 1) {
        const g: string = dbResultGet(rG, i, 0);
        if (g == mftGroup) {
            drug       = dbResultGet(rG, i, 1);
            sourceNote = dbResultGet(rG, i, 2);
            break;
        }
    }
    const rS = dbQuery(db,
        "SELECT drug, trimester_1_allowed, fallback_drug "
      + "FROM antimalarial_pregnancy_safety");
    const nS: i64 = dbResultRowCount(rS);
    let t1Allowed:    string = "";
    let fallbackDrug: string = "";
    for (let i: i64 = 0; i < nS; i = i + 1) {
        const d: string = dbResultGet(rS, i, 0);
        if (d == drug) {
            t1Allowed    = dbResultGet(rS, i, 1);
            fallbackDrug = dbResultGet(rS, i, 2);
            break;
        }
    }
    dbDisconnect(db);

    if (drug.length() == 0) {
        return "500{"
             + "\"task\":\"first-line\","
             + "\"error\":\"mft_current_drug has no row for group " + jsonEscape(mftGroup) + ". The MFT rotation has not been configured — INSERT INTO mft_current_drug (group_letter, drug, effective_from) VALUES ('" + jsonEscape(mftGroup) + "', '<AL|ASPY|DHAP>', current_date) per the latest RBC bulletin.\","
             + "\"district\":\""  + jsonEscape(districtName) + "\","
             + "\"mftGroup\":\""  + jsonEscape(mftGroup) + "\","
             + "\"auditId\":\""   + jsonEscape(auditId) + "\""
             + "}";
    }

    const t1Bool       = t1Allowed == "t";
    const districtField = districtName.length() > 0
        ? "\"district\":\"" + jsonEscape(districtName) + "\""
        : "\"district\":null";
    const provinceField = province.length() > 0
        ? "\"province\":\"" + jsonEscape(province) + "\""
        : "\"province\":null";
    return "200{"
         + "\"task\":\"first-line\","
         + "\"language\":\""        + lang + "\","
         + "\"protocol\":\"RBC 2024\","
         + districtField + ","
         + provinceField + ","
         + "\"mftGroup\":\""        + jsonEscape(mftGroup) + "\","
         + "\"mftContextSource\":\"" + jsonEscape(mftCtxSource) + "\","
         + "\"drug\":\""            + jsonEscape(drug) + "\","
         + "\"pregnancySafety\":{"
         +   "\"trimester1\":\""  + (t1Bool ? "allowed" : "contraindicated") + "\","
         +   "\"trimester2_3\":\"allowed\","
         +   "\"fallbackDrug\":"  + (fallbackDrug.length() > 0 ? "\"" + jsonEscape(fallbackDrug) + "\"" : "null")
         + "},"
         + "\"pregnancySafetySource\":\"deterministic:rbc-2024-pregnancy-safety-matrix\","
         + "\"narrativeSource\":\"deterministic:rbc-2024-mft-district-group-rotation\","
         + "\"currentRotationSource\":\"" + jsonEscape(sourceNote) + "\","
         + "\"auditId\":\""         + jsonEscape(auditId) + "\","
         + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function firstLineHandler(req: ptr, res: ptr): void {
    counter_inc(slotFirstLine());
    const auditId  = generateAuditId();
    const lang     = langFromQuery(req);
    const district = districtFromQuery(req);
    const out      = doFirstLine("RW", district, lang, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

// /v1/iptp — IPTp-SP protocol metadata. Read-only. Single row in
// iptp_protocol seeded from the RBC handbook: SP, 3 tablets per dose
// (1500/75 mg), starting from week 13 gestation, ≥3 doses ≥4 weeks
// apart, DOT delivery at every ANC visit. The contraindications field
// is the cardinal CHW reminder ("not in 1st trimester; not for HIV+
// women on cotrim"). pregnancyHandler also surfaces this same data
// inline (as an "iptp" field) when trim>=2.
// Each doX() pure function returns "NNN{json...}" — three-digit
// HTTP status code prefix followed by the response body. HTTP
// handlers extract both with these two helpers. The chat
// orchestrator can use the same shape (status to detect failure,
// body to feed the LLM for prose-wrapping).
function doxStatus(out: string): i32 {
    return (Number(out.substring(0, 3)) as i64) as i32;
}

function doxBody(out: string): string {
    return out.substring(3, out.length());
}

// Pure function for the IPTp metadata response. Returns
// "NNN{json...}" where NNN is the 3-digit HTTP status code.
// Used by both iptpHandler (HTTP) and /v1/chat (chat orchestrator).
function doIptp(country: string, lang: string, auditId: string): string {
    const proto    = protocolForCountry(country);
    const protoCite = (country == "RW") ? "RBC 2024" : "WHO 2024";
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT drug, tablets_per_dose, mg_per_dose, weeks_start, "
      + "       min_doses, interval_weeks, contraindications_en, "
      + "       contraindications_rw, delivery "
      + "FROM iptp_protocol "
      + "WHERE protocol_id = '" + sqlEscape(proto) + "' LIMIT 1");
    const drug:          string = dbResultGet(r, 0, 0);
    const tabletsStr:    string = dbResultGet(r, 0, 1);
    const mgStr:         string = dbResultGet(r, 0, 2);
    const weeksStartStr: string = dbResultGet(r, 0, 3);
    const minDosesStr:   string = dbResultGet(r, 0, 4);
    const intervalStr:   string = dbResultGet(r, 0, 5);
    const contraEn:      string = dbResultGet(r, 0, 6);
    const contraRw:      string = dbResultGet(r, 0, 7);
    const delivery:      string = dbResultGet(r, 0, 8);
    dbDisconnect(db);

    if (drug.length() == 0) {
        return "500{\"task\":\"iptp\","
             + "\"error\":\"iptp_protocol lookup failed (DB unreachable or no row)\","
             + "\"auditId\":\"" + auditId + "\""
             + "}";
    }

    const contra = lang == "rw" ? contraRw : contraEn;

    // Canonical reviewed per-language prose interpolated from the
    // DB-loaded fields. The LLM must emit this verbatim per
    // chatWrapClinicalPrompt rule 10; letting it freely compose IPTp prose
    // in Kinyarwanda produced word salad ("ishyirwa mumaguru",
    // "icyabutaka", "ibiro 1500/75 mg", etc.).
    // Caveat is no longer prepended here — chatHandler prepends it
    // server-side after the LLM call, which prevents the LLM from
    // substituting the country name.
    let narrative: string;
    if (lang == "rw") {
        narrative = "IPTp (Intermittent Preventive Treatment mu butwite) ni "
                  + "uburyo bwo gukumira malariya mu bagore batwite. "
                  + "Dukurikije amabwiriza ya " + protoCite + ": umuha "
                  + drug + " (sulfadoxine-pyrimethamine), ibinini "
                  + tabletsStr + " buri doze (" + mgStr + "). "
                  + "Umubyeyi afatira uwo muti imbere y'inshuti y'ubuzima, "
                  + "igihe umubyeyi aje kwivuza, guhera ku byumweru "
                  + weeksStartStr + " by'ubutwite. Nibura doze "
                  + minDosesStr + " zirakenewe mu butwite bwose; "
                  + "hagati ya buri doze hagomba kuba nibura ibyumweru "
                  + intervalStr + ". Ibitemewe: " + contraRw;
    } else {
        // Drop the "(Inshuti y'Ubuzima)" Kinyarwanda gloss from the
        // EN narrative — it's a Rwanda-specific CHW name that doesn't
        // generalise across countries. Non-RW users see just "CHW";
        // Rwanda users typically pick lang=rw which routes to the
        // Kinyarwanda branch above which uses "inshuti y'ubuzima"
        // natively.
        narrative = "IPTp (Intermittent Preventive Treatment in pregnancy) "
                  + "is a way of preventing malaria in pregnant women. "
                  + "Per " + protoCite + " guidelines: give " + drug
                  + " (sulfadoxine-pyrimethamine), " + tabletsStr
                  + " tablets per dose (" + mgStr + "). "
                  + "The mother takes the drug in front of the CHW when "
                  + "she comes for care, starting at " + weeksStartStr
                  + " weeks of pregnancy. At least " + minDosesStr
                  + " doses are needed across the whole pregnancy; "
                  + "there must be at least " + intervalStr
                  + " weeks between each dose. Contraindications: " + contraEn;
    }

    return "200{"
         + "\"task\":\"iptp\","
         + "\"language\":\""        + lang + "\","
         + "\"protocol\":\"RBC 2024\","
         + "\"drug\":\""            + drug + "\","
         + "\"tabletsPerDose\":"    + tabletsStr + ","
         + "\"mgPerDose\":\""       + jsonEscape(mgStr) + "\","
         + "\"weeksStart\":"        + weeksStartStr + ","
         + "\"minDoses\":"          + minDosesStr + ","
         + "\"intervalWeeks\":"     + intervalStr + ","
         + "\"delivery\":\""        + jsonEscape(delivery) + "\","
         + "\"contraindications\":\"" + jsonEscape(contra) + "\","
         + "\"narrative\":\""       + jsonEscape(narrative) + "\","
         + "\"narrativeSource\":\"deterministic:rbc-2024-iptp-protocol\","
         + "\"auditId\":\""         + auditId + "\","
         + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function iptpHandler(req: ptr, res: ptr): void {
    counter_inc(slotIptp());
    const auditId = generateAuditId();
    const lang    = langFromQuery(req);
    const out     = doIptp("RW", lang, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

// /v1/vaccines — malaria vaccine schedule metadata. Read-only. Returns
// every vaccine in the vaccines table with its dose schedule from
// vaccine_doses joined Abe-side (two queries; pairing by vaccine_id).
// Today the seed has RTS,S/AS01 with 4 doses (5/6/7/24 months) and
// R21/Matrix-M with no dose rows yet. Eligibility text is per
// Rwanda's transmission-stratified rollout.
function doVaccines(country: string, lang: string, auditId: string): string {
    const db = dbConnect("dbname=malariachat");
    const rV = dbQuery(db,
        "SELECT vaccine_id, name, target, "
      + "       age_eligibility_en, age_eligibility_rw "
      + "FROM vaccines ORDER BY vaccine_id");
    const nV: i64 = dbResultRowCount(rV);

    const rD = dbQuery(db,
        "SELECT vaccine_id, dose_number, age_months, notes_en, notes_rw "
      + "FROM vaccine_doses ORDER BY vaccine_id, dose_number");
    const nD: i64 = dbResultRowCount(rD);

    if (nV == 0) {
        dbDisconnect(db);
        return "500{\"task\":\"vaccines\","
             + "\"error\":\"vaccines lookup failed (DB unreachable or no rows)\","
             + "\"auditId\":\"" + auditId + "\""
             + "}";
    }

    let vaccinesJson: string = "[";
    for (let i: i64 = 0; i < nV; i = i + 1) {
        if (i > 0) vaccinesJson = vaccinesJson + ",";
        const vid:     string = dbResultGet(rV, i, 0);
        const vname:   string = dbResultGet(rV, i, 1);
        const vtarget: string = dbResultGet(rV, i, 2);
        const veligEn: string = dbResultGet(rV, i, 3);
        const veligRw: string = dbResultGet(rV, i, 4);
        const velig = lang == "rw" ? veligRw : veligEn;

        let dosesJson: string = "[";
        let firstDose: bool   = true;
        for (let j: i64 = 0; j < nD; j = j + 1) {
            const dvid: string = dbResultGet(rD, j, 0);
            if (dvid == vid) {
                if (!firstDose) dosesJson = dosesJson + ",";
                firstDose = false;
                const dnumStr:  string = dbResultGet(rD, j, 1);
                const dageStr:  string = dbResultGet(rD, j, 2);
                const dnoteEn:  string = dbResultGet(rD, j, 3);
                const dnoteRw:  string = dbResultGet(rD, j, 4);
                const dnote = lang == "rw" ? dnoteRw : dnoteEn;
                dosesJson = dosesJson
                          + "{\"doseNumber\":" + dnumStr
                          + ",\"ageMonths\":"  + dageStr
                          + ",\"notes\":\""    + jsonEscape(dnote) + "\"}";
            }
        }
        dosesJson = dosesJson + "]";

        vaccinesJson = vaccinesJson
                     + "{\"id\":\""             + jsonEscape(vid) + "\","
                     + "\"name\":\""            + jsonEscape(vname) + "\","
                     + "\"target\":\""          + vtarget + "\","
                     + "\"ageEligibility\":\""  + jsonEscape(velig) + "\","
                     + "\"doses\":"             + dosesJson + "}";
    }
    vaccinesJson = vaccinesJson + "]";
    dbDisconnect(db);

    return "200{"
         + "\"task\":\"vaccines\","
         + "\"language\":\""     + lang + "\","
         + "\"protocol\":\"RBC 2024\","
         + "\"vaccines\":"       + vaccinesJson + ","
         + "\"narrativeSource\":\"deterministic:rbc-2024-vaccine-schedule\","
         + "\"auditId\":\""      + auditId + "\","
         + "\"reviewBanner\":\"" + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function vaccinesHandler(req: ptr, res: ptr): void {
    counter_inc(slotVaccines());
    const auditId = generateAuditId();
    const lang    = langFromQuery(req);
    const out     = doVaccines("RW", lang, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

// ===========================================================================
// malariaChat — /v1/chat orchestrator
// ===========================================================================
// Key invariants:
//   - Conversation state in PostgreSQL (chat_conversations, chat_messages).
//   - 3-hour inactivity auto-close.
//   - Deterministic keyword intent classifier (no LLM in the classifier).
//   - Clinical intents route to the existing doX() pure functions.
//   - Open Q&A goes straight to llmChat.
//   - Offline degraded mode: clinical paths fall back to the structured
//     "narrative" field from doX; open Q&A returns a bilingual canned
//     message.
//   - LLM-backend swap point: only llmChat() in llm.abe changes.

// ── JSON / SQL helpers ──────────────────────────────────────────────────────

// Naive jsonExtractString — looks for "key":"value" and returns value
// up to the next unescaped quote. CHW message JSON from the UI does
// not contain backslash-escaped quotes in practice (jsonEscape is
// only applied when WE build outbound JSON; inbound is generated by
// the UI's JSON.stringify, which produces properly-escaped strings,
// but escape sequences inside string values are rare in the field
// shape we care about — conversationId, lang, district, message
// — all of which are simple strings). Good enough for Phase 1.
function jsonExtractString(json: string, key: string): string {
    const opener = "\"" + key + "\":\"";
    const start  = json.indexOf(opener);
    if (start < 0) return "";
    const valueStart = start + opener.length();
    const tail = json.substring(valueStart, json.length());
    const closeRel = tail.indexOf("\"");
    if (closeRel < 0) return "";
    return tail.substring(0, closeRel);
}

// PostgreSQL string escape — double the single quotes. We use string
// concatenation to build SQL for chat_conversations / chat_messages
// because we do not yet have a parameterised query builtin
// (dbQueryParams exists in runtime but isn't exposed via codegen).
// Without sqlEscape on user-supplied content, a CHW message with an
// apostrophe ("don't") would syntax-error the INSERT.
function sqlEscape(s: string): string {
    return s.replace("'", "''");
}

// ── Conversation lifecycle ──────────────────────────────────────────────────

// Generate a fresh conversation_id. Same shape as audit IDs but with
// CONV in the middle so they're visually distinct in logs.
function chatGenerateConversationId(): string {
    return "MLW-CONV-" + time_us();
}

// chatGetOrCreateConversation:
//   - If reqConvId is empty OR no open row exists OR last_activity_at
//     was more than 3 hours ago, mark the stale row closed (if any),
//     create a fresh row, return the new id.
//   - Otherwise bump last_activity_at on the existing row, return its id.
//   On every turn we also write through the settings-panel fields
//   (user_name, country) onto the row so the CHW can edit them
//   mid-conversation in the right-column panel and have them stick.
function chatGetOrCreateConversation(reqConvId: string, lang: string, district: string,
                                     userName: string, country: string,
                                     email: string, phone: string): string {
    const db = dbConnect("dbname=malariachat");
    let useExisting: bool = false;
    if (reqConvId.length() > 0) {
        const r = dbQuery(db,
            "SELECT conversation_id FROM chat_conversations "
          + "WHERE conversation_id = '" + sqlEscape(reqConvId) + "' "
          + "  AND closed_at IS NULL "
          + "  AND last_activity_at > NOW() - INTERVAL '3 hours' "
          + "LIMIT 1");
        const n: i64 = dbResultRowCount(r);
        if (n > 0) useExisting = true;
    }

    const safeUserName = userName.length() > 0
        ? "'" + sqlEscape(userName) + "'"
        : "NULL";
    const safeCountry  = "'" + sqlEscape(country) + "'";
    const safeDistrict = district.length() > 0
        ? "'" + sqlEscape(district) + "'"
        : "NULL";
    const safeEmail    = email.length() > 0
        ? "'" + sqlEscape(email) + "'"
        : "NULL";
    const safePhone    = phone.length() > 0
        ? "'" + sqlEscape(phone) + "'"
        : "NULL";

    if (useExisting) {
        // Bump activity timestamp; refresh modal fields so a
        // mid-conversation change in the Settings modal propagates
        // immediately.
        dbQuery(db,
            "UPDATE chat_conversations "
          + "SET last_activity_at = NOW(), "
          + "    user_name = " + safeUserName + ", "
          + "    country   = " + safeCountry  + ", "
          + "    district  = " + safeDistrict + ", "
          + "    email     = " + safeEmail    + ", "
          + "    phone     = " + safePhone    + " "
          + "WHERE conversation_id = '" + sqlEscape(reqConvId) + "'");
        dbDisconnect(db);
        return reqConvId;
    }

    // Auto-close any stale row with this id (idempotent).
    if (reqConvId.length() > 0) {
        dbQuery(db,
            "UPDATE chat_conversations SET closed_at = NOW() "
          + "WHERE conversation_id = '" + sqlEscape(reqConvId) + "' "
          + "  AND closed_at IS NULL");
    }

    // Create a fresh conversation.
    const newId = chatGenerateConversationId();
    const safeLang     = (lang == "en" || lang == "rw") ? lang : "en";
    dbQuery(db,
        "INSERT INTO chat_conversations "
      + "  (conversation_id, lang, district, user_name, country, email, phone) "
      + "VALUES "
      + "  ('" + sqlEscape(newId) + "', '" + safeLang + "', "
      +        safeDistrict + ", " + safeUserName + ", " + safeCountry + ", "
      +        safeEmail + ", " + safePhone + ")");
    dbDisconnect(db);
    return newId;
}

// chatGetConversationDistrict — read back the conversation's district
// (set at create-time). Used to fall back when the per-message
// request didn't carry one.
function chatGetConversationDistrict(convId: string): string {
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT COALESCE(district, '') FROM chat_conversations "
      + "WHERE conversation_id = '" + sqlEscape(convId) + "' LIMIT 1");
    const out: string = dbResultGet(r, 0, 0);
    dbDisconnect(db);
    return out;
}

// Persist one chat turn. role is 'user' or 'assistant'. intent /
// structuredJson / structuredEndpoint are empty strings for user
// turns and for open-Q&A assistant turns; populated on clinical
// assistant turns so the audit log captures the structured result.
function chatPersistMessage(convId: string, role: string, text: string,
                            intent: string, structuredJson: string,
                            structuredEndpoint: string,
                            auditIdArg: string): void {
    const db = dbConnect("dbname=malariachat");
    const sql = "INSERT INTO chat_messages "
              + "  (conversation_id, role, text, intent, "
              + "   structured_json, structured_endpoint, audit_id) "
              + "VALUES "
              + "  ('" + sqlEscape(convId) + "', "
              + "   '" + sqlEscape(role)   + "', "
              + "   '" + sqlEscape(text)   + "', "
              + "   '" + sqlEscape(intent) + "', "
              + "   '" + sqlEscape(structuredJson) + "', "
              + "   '" + sqlEscape(structuredEndpoint) + "', "
              + "   '" + sqlEscape(auditIdArg) + "')";
    dbQuery(db, sql);
    dbDisconnect(db);
}

// chatReconstructHistory — build the JSON array of prior turns for
// llmChat's conversationJson parameter. Last N turns in chronological
// order. Excludes assistant turns whose text is empty (defensive).
function chatReconstructHistory(convId: string, maxTurns: i64): string {
    const db = dbConnect("dbname=malariachat");
    // Most-recent-N first, then we'll reverse client-side.
    const r = dbQuery(db,
        "SELECT role, text FROM chat_messages "
      + "WHERE conversation_id = '" + sqlEscape(convId) + "' "
      + "  AND role IN ('user','assistant') "
      + "ORDER BY created_at DESC LIMIT " + maxTurns);
    const n: i64 = dbResultRowCount(r);
    dbDisconnect(db);
    if (n == 0) return "[]";

    // Build in reverse order (oldest first). We have rows in DESC
    // order so iterate from the END of the result toward the start.
    let json: string = "[";
    let first: bool = true;
    let i: i64 = n - 1;
    while (i >= 0) {
        const role: string = dbResultGet(r, i, 0);
        const text: string = dbResultGet(r, i, 1);
        if (text.length() > 0) {
            if (!first) json = json + ",";
            first = false;
            json = json + "{\"role\":\"" + role + "\",\"content\":\""
                       + jsonEscape(text) + "\"}";
        }
        i = i - 1;
    }
    json = json + "]";
    return json;
}

// ── Intent classifier (deterministic, no LLM) ───────────────────────────────

// Priority order matters: clinical-safety triggers (danger, TF) come
// first; pregnancy before dose because Phase 1 picks pregnancy on
// multi-intent inputs. Each rule returns immediately on first match.
function classifyChatIntent(lower: string, lang: string): string {
    if (dangerHitCount(lower, lang) > 0)   return "danger";
    if (treatmentFailureDetected(lower))   return "danger";
    if (isPregnant(lower))                 return "pregnancy";
    if (parseWeightKg(lower) > 0.0)        return "dose";

    if (lower.indexOf("iptp") >= 0
        || lower.indexOf("itpt") >= 0                    // common letter-swap typo
        || lower.indexOf("ipt-p") >= 0
        || lower.indexOf("intermittent preventive") >= 0
        || lower.indexOf("prevention in pregnancy") >= 0
        || lower.indexOf("kurinda mu nda") >= 0
        || lower.indexOf("kuzuia malaria kwa wajawazito") >= 0
        || lower.indexOf("kuzuia malaria katika ujauzito") >= 0
        || lower.indexOf("tpig") >= 0                    // French abbreviation (TPIg = …pendant la grossesse)
        || lower.indexOf("tpi") >= 0                     // legacy French abbreviation (still accepted as input)
        || lower.indexOf("traitement préventif intermittent") >= 0
        || lower.indexOf("traitement preventif intermittent") >= 0) return "iptp";

    if (lower.indexOf("vaccine") >= 0
        || lower.indexOf("rts,s") >= 0
        || lower.indexOf("r21") >= 0
        || lower.indexOf("urukingo") >= 0
        || lower.indexOf("inkingo") >= 0)  return "vaccines";

    if (lower.indexOf("first-line") >= 0
        || lower.indexOf("first line") >= 0
        || lower.indexOf("mft") >= 0
        || lower.indexOf("rotation") >= 0
        || lower.indexOf("umuti wa mbere") >= 0
        || lower.indexOf("ihinduka ry'imiti") >= 0) return "first-line";

    // Bare district name with no other intent → user is probably
    // asking what their district uses.
    if (parseDistrict(lower).length() > 0) return "first-line";

    return "open";
}

// ── System prompt builders ──────────────────────────────────────────────────

// Wrap-clinical: the LLM is paraphrasing a structured JSON result
// into chat-friendly prose.
function chatWrapClinicalPrompt(country: string, lang: string): string {
    let s = "You are MalariaChat, a clinical chatbot for community health "
          + "workers and trainees in Rwanda (production) and Tanzania / "
          + "Kenya (teaching mode, WHO 2024 baseline).\n\n"
          + "RESPOND IN: " + langFull(lang) + ".\n\n";
    if (lang == "rw") {
        s = s + rwStyleGuide() + "\n\n";
    }
    if (lang == "sw") {
        s = s + swStyleGuide() + "\n\n";
    }
    // The educational caveat is NOT injected via the system prompt: the
    // LLM was observed substituting the country name when emitting it
    // (e.g. wrote "Tanzania" for a Zambia user). The caveat is prepended
    // server-side in chatHandler so the country name and language are
    // locked and no LLM paraphrase can interfere.
    s = s + "A deterministic clinical engine has just produced a STRUCTURED "
          + "JSON result for the user's question. Paraphrase that JSON into "
          + "a conversational reply.\n\n"
          + "STRICT RULES — non-negotiable:\n"
          + "1. Do NOT invent values. Every clinical fact in your reply must "
          + "come from the structured result. Numbers (kg, tablets, doses, "
          + "weeks, mg), drug names (AL/ASPY/DHAP), district names, MFT group "
          + "letters, age/weight bands — all must match the structured result "
          + "exactly. Do NOT invent band ranges like \"10–<14\" that aren't in "
          + "the result.\n"
          + "2. METADATA-ONLY GATING (most important rule for safety). The "
          + "structured result MAY OR MAY NOT contain a verifiedDose field "
          + "and/or a verifiedTrimester field:\n"
          + "   - If structured.verifiedDose is present and not null: "
          + "paraphrase those exact fields (weightKg, drug, band, tablets, "
          + "schedule). Do not embellish with additional dose detail.\n"
          + "   - If structured.verifiedTrimester is present and not null: "
          + "paraphrase those exact fields.\n"
          + "   - If NEITHER is present (result came from /v1/first-line, "
          + "/v1/iptp, /v1/vaccines metadata-only paths, or a non-severe "
          + "/v1/danger): you may NOT mention specific tablet counts, dose "
          + "schedules, mg amounts, or weight bands. The result tells you "
          + "WHICH drug applies; you must NOT compute or invent the dose. "
          + "If the user clearly wants a dose calculation, redirect: \"For "
          + "a dose calculation tell me the patient's weight, RDT result, "
          + "and district.\" / In RW: \"Kugira ngo nshobore guhitamo doze, "
          + "mbwira uburemere bw'umurwayi, igisubizo cya RDT, n'akarere.\"\n"
          + "3. Keep protocol markers verbatim: [DOSE_ALERT], "
          + "[PROTOCOL_REVIEW_REQUIRED], [KOHEREZA], [BIMENYETSO_BIBI]. Do not "
          + "translate or paraphrase them.\n"
          + "4. Keep responses short and CHW-readable. 3-5 sentences. No "
          + "medical jargon beyond what's already in the structured result.\n";
    if (country == "RW") {
        s = s + "5. If structured.mftContextSource == \"default-group-a\", "
              + "append EXACTLY one of the following sentences as a paragraph "
              + "(separate from the [DOSE_ALERT] paragraph and from any rule-6 "
              + "PLACEHOLDER paragraph — they may both fire on the same turn). "
              + "Emit it word-for-word; do NOT compose it freely. Use the "
              + "language matching RESPOND IN; do not mix languages. Always — "
              + "every turn, even if mentioned earlier:\n"
              + "   • EN: \"Note: defaulting to Group A — please set your "
              + "district in Settings (gear icon, bottom-left) so I can apply "
              + "your area's correct MFT rotation.\"\n"
              + "   • RW: \"Icyitonderwa: dukoresheje itsinda A nk'ibisanzwe "
              + "— hitamo akarere kawe mu rutonde rw'igenamiterere "
              + "(akamenyetso ko hasi ibumoso) kugira ngo nshobore "
              + "gukoresha MFT y'ahantu ukorera.\"\n"
              + "6. If structured.currentRotationSource contains \"PLACEHOLDER\", "
              + "append EXACTLY one of the following sentences as the final "
              + "paragraph. Emit it word-for-word; do NOT compose it freely "
              + "(prior compositions produced wrong-register Kinyarwanda like "
              + "\"mwamusanze PLACEHOLDER\"). Use the language matching "
              + "RESPOND IN; do not mix languages:\n"
              + "   • EN: \"Note: the MFT rotation for this district is "
              + "provisional — please confirm against the latest RBC bulletin "
              + "before acting on the drug choice.\"\n"
              + "   • RW: \"Icyitonderwa: ihitamo ry'umuti wa MFT mu karere "
              + "rigomba kugenzurwa mu mabwiriza ya RBC ya nyuma mbere y'uko "
              + "mukoresha umuti.\"\n";
    } else {
        // Phase A teaching mode: rules 5 and 6 are Rwanda MFT-specific
        // and must NOT fire for Tanzania / Kenya. Even though
        // structured.mftContextSource or currentRotationSource may still
        // appear in the JSON (the doX functions still use RBC-2024 SQL
        // internally — Phase B), the LLM should suppress those notes
        // entirely for non-RW countries. An English MFT / RBC-bulletin
        // note was observed appearing in a Kenya response — this rule
        // closes that gap.
        s = s + "5. [RWANDA-SPECIFIC — does not apply outside Rwanda.] "
              + "If structured.mftContextSource appears (e.g. \"default-"
              + "group-a\"), IGNORE IT. Do NOT mention MFT, group-A defaults, "
              + "Rwanda districts, or Settings district suggestions. The "
              + "Multiple First-Line Therapy rotation is a Rwanda policy; "
              + "it does not apply in teaching-mode (WHO 2024 baseline) for "
              + "Tanzania or Kenya.\n"
              + "6. [RWANDA-SPECIFIC — does not apply outside Rwanda.] "
              + "If structured.currentRotationSource contains "
              + "\"PLACEHOLDER\", IGNORE IT. Do NOT mention RBC bulletin, "
              + "MFT rotation, or Rwanda protocol provisional status in "
              + "a non-Rwanda response. The teaching-mode caveat at the "
              + "top of your reply already carries the appropriate "
              + "\"consult national programme\" framing.\n";
    }
    s = s + "7. If the result indicates severe (action: \"REFER_IMMEDIATELY\" "
          + "or severeGate: true), LEAD WITH THE REFERRAL.\n"
          + "8. NO PREAMBLE, NO INPUT ECHO. Do not open the reply with a "
          + "sentence that acknowledges or restates what the user told you. "
          + "Forbidden openings include things like \"Ushyirwaho kwa "
          + "district X\", \"Set for district X\", \"You said weight N kg\", "
          + "\"Noted RDT positive\", \"Murakoze kuvuga ko...\", \"OK\", "
          + "\"Sawa\". The deterministic engine already validated those "
          + "inputs; do not echo them. Acceptable openings are EXACTLY one "
          + "of: (a) a salutation IN THE SAME LANGUAGE AS RESPOND IN — "
          + "use \"Health worker,\" only when RESPOND IN is English, "
          + "\"Nshuti z'Ubuzima,\" only when RESPOND IN is Kinyarwanda, "
          + "\"Watoa huduma za afya,\" only when RESPOND IN is Swahili, "
          + "\"Agent de santé,\" only when RESPOND IN is French. NEVER use "
          + "a Kinyarwanda salutation on a French / Swahili / English "
          + "response (e.g. \"Nshuti z'Ubuzima,\" must never leak onto "
          + "a Burundi+French response — this is forbidden); or (b) the "
          + "first clinical sentence directly. Nothing else is allowed "
          + "before the clinical content.\n"
          + "9. NO STANDALONE PROTOCOL-REVIEW SENTENCE. The "
          + "[PROTOCOL_REVIEW_REQUIRED] banner is shown permanently in the "
          + "UI — you do NOT need to restate it in the chat bubble. Do not "
          + "produce sentences like \"Check these doses against the RBC 2024 "
          + "guidelines\", \"Reba imbonerahamwe y'RBC 2024 mbere...\", "
          + "\"Manikiwe neza...\", or any other variant. The DOSE_ALERT "
          + "marker (when present in the narrative) already carries the "
          + "per-turn review reminder; emit it where the narrative places "
          + "it and stop there. Specifically: do NOT translate any English "
          + "boilerplate from the structured result into Kinyarwanda — when "
          + "uncertain, OMIT.\n"
          + "10. CANONICAL NARRATIVE — emit verbatim. If the structured "
          + "result includes a non-null \"narrative\" field, that prose "
          + "IS the body of your reply. Emit it verbatim. Allowed: a "
          + "salutation prefix per rule 8 (e.g. \"Nshuti z'Ubuzima,\" / "
          + "\"Health worker,\"); line breaks between sentences for "
          + "readability; preservation of protocol markers per rule 3. "
          + "NOT allowed: rephrasing, translating into another language, "
          + "summarising, re-ordering, or adding any clinical detail. "
          + "The narrative is canonical prose verified against the "
          + "protocol; the discrete fields (drug, tablets, mg, weeks, "
          + "doses, contraindications) are already inside it — do NOT "
          + "restate them separately. Applies to /v1/assess, /v1/iptp, "
          + "and any future endpoint that emits a narrative field. If "
          + "rule 5 (default-A note) or rule 6 (PLACEHOLDER note) also "
          + "fires, append THOSE canonical sentences AFTER the narrative.\n"
          + "10a. ANTI-PARAPHRASE for non-English narratives. When the "
          + "narrative is in Kinyarwanda or Swahili, emit it CHARACTER-"
          + "FOR-CHARACTER. Do NOT make synonym substitutions like "
          + "\"wamama\" → \"wanawake\", \"chenye mafuta\" → \"kisicho "
          + "na mafuta\" (THIS IS THE OPPOSITE MEANING — fat-containing "
          + "vs without-fat — clinically wrong), \"hospitalini\" → "
          + "\"kwa daktari\". These are NOT equivalent for a clinical "
          + "audience and the canonical wording is the reviewed one. "
          + "If you find yourself reaching for an apparent synonym, "
          + "STOP and emit the canonical word.\n"
          + "10b. TRANSLATION GUARDRAILS. If the narrative is in "
          + "English and RESPOND IN is `rw` or `sw`, you MAY translate "
          + "it — but preserve every numeric value (mg, weight, weeks, "
          + "tablets, doses), every drug name (AL, SP, DHAP, ASPY, "
          + "artemisinin, lumefantrine, etc.), every administration "
          + "route (oral / rectal / IM / IV — do NOT translate "
          + "\"rectal\" as \"kwa sehemu ya tumboni\" or any other "
          + "anatomical paraphrase; keep \"rectal\" as a loanword or "
          + "use \"kwa njia ya mkundu\"), and the polarity of clinical "
          + "statements (do NOT flip \"with fat\" → \"without fat\"). "
          + "When in doubt, fall back to the English term rather than "
          + "produce a wrong translation.\n\n"
          + "You are NOT a clinician. You wrap clinical guidance the "
          + "deterministic engine computed; you never reason about doses "
          + "yourself. If you're unsure whether a fact is in the structured "
          + "result, omit it.";
    return s;
}

// Open-Q&A: no deterministic engine result; LLM answers from training.
// No RAG retrieval yet (a future phase could add tsvector).
function chatOpenQAPrompt(country: string, lang: string): string {
    let s = "You are MalariaChat, a clinical chatbot for community health "
          + "workers and trainees in Rwanda (production) and Tanzania / "
          + "Kenya (teaching mode, WHO 2024 baseline).\n\n"
          + "RESPOND IN: " + langFull(lang) + ".\n\n";
    if (lang == "rw") {
        s = s + rwStyleGuide() + "\n\n";
    }
    if (lang == "sw") {
        s = s + swStyleGuide() + "\n\n";
    }
    // Phase A: see chatWrapClinicalPrompt — caveat is now server-side
    // prepended in chatHandler, not LLM-emitted.
    s = s + "The user has asked an open-ended question that does NOT need a "
          + "clinical-precision answer (no specific dose, no severity check, "
          + "no pregnancy/trimester decision, no district lookup). Answer "
          + "from your training knowledge, but follow these rules:\n\n"
          + "1. If you don't know, say so. Don't guess clinical content.\n"
          + "2. Default to handbook-aligned answers: RBC 2024 (5th edition) "
          + "Integrated Malaria Control Guidelines, and the CHW handbook "
          + "(Malariya Igitabo cy'Umujyanama).\n"
          + "3. For Rwandan operational facts you almost certainly don't "
          + "know currently (which district is in which MFT group's current "
          + "rotation, real-time stockouts, current district transmission "
          + "stratification, any individual patient's record) — say \"ask "
          + "your supervisor or check the latest RBC bulletin / DHIS2.\"\n"
          + "4. Keep responses short — 3-5 sentences. CHW-readable.\n"
          + "5. NEVER recommend a specific drug dose, dose count, or "
          + "schedule. If the user asks for one, redirect: \"I can compute "
          + "that for you — tell me the patient's weight, RDT result, and "
          + "your district.\"\n"
          + "6. End every clinical-content response with a brief "
          + "[PROTOCOL_REVIEW_REQUIRED] reminder.";
    return s;
}

// ── Offline degraded mode ───────────────────────────────────────────────────

// Used when llmChat returns "" (API key missing or network error).
// Phase 1: bilingual canned message. Future phases can add more
// nuance (degraded-but-still-useful redirects).
function chatOfflineFallback(lang: string): string {
    if (lang == "rw") {
        return "Hano nshobora gusubiza ibibazo by'imiti, ibimenyetso bibi, "
             + "no kubaza ku byumweru by'inda nta LLM. Ku bibazo bigoye, "
             + "ongera ugerageze nyuma cyangwa ubaze umugenzuzi wawe.";
    }
    return "I can answer dose, severity, and pregnancy questions without "
         + "the LLM. For other questions, try again later or ask your "
         + "supervisor.";
}

// Extract the "narrative" field out of a doX-produced structured JSON
// for use as an offline-degraded clinical reply. Returns "" when no
// narrative field exists (e.g. /v1/iptp, /v1/vaccines, /v1/first-line
// don't have one).
function chatNarrativeFallback(structuredJson: string): string {
    return jsonExtractString(structuredJson, "narrative");
}

// chatStripReviewBanner — remove the trailing reviewBanner field from
// a doX-produced JSON before handing it to the LLM. The banner is
// English boilerplate already shown as a permanent banner in the UI;
// when the LLM saw it inside the structured result it kept trying to
// translate the English sentence into Kinyarwanda and produced
// invented words like "Manikiwe", "idositra", "atukurikiza",
// "amahitamo". Stripping it from the LLM's view eliminates the
// translation target. The client response still carries the banner
// — only the LLM's structured input is filtered.
//
// Every doX function emits "reviewBanner" as the LAST field, so the
// pattern ,"reviewBanner":"..."} is unambiguous and lopping from the
// preceding comma to end-of-string then re-adding } is safe.
function chatStripReviewBanner(json: string): string {
    const marker = ",\"reviewBanner\":\"";
    const idx: i64 = json.indexOf(marker);
    if (idx < 0) return json;
    return json.substring(0, idx) + "}";
}

// ── Country gating (settings panel) ─────────────────────────────────────────
// MalariaChat's clinical content (MFT, weight bands, RBC prose) is
// Rwanda-specific. The settings panel lets the CHW pick a country so
// the system knows where they are working, but every country other
// than RW short-circuits with a "not supported yet" message. Coverage
// for Burundi/DRC/Kenya/Tanzania/Uganda/Zambia is on the roadmap.

function isAllowedCountryCode(code: string): bool {
    if (code == "RW") return true;
    if (code == "BI") return true;
    if (code == "CD") return true;
    if (code == "KE") return true;
    if (code == "TZ") return true;
    if (code == "UG") return true;
    if (code == "ZM") return true;
    return false;
}

// Phase A: country → protocol_id dispatch. Rwanda runs the local
// MOPDD / RBC 2024 protocol; Tanzania, Kenya, Uganda, and Zambia
// users (teaching mode) get the WHO Global Malaria Programme
// baseline. UG/ZM are English-only at the UI layer (no Swahili /
// Kinyarwanda labels for those audiences). Other countries return
// "" — the chatHandler short-circuit blocks them with the
// country-not-supported response.
function protocolForCountry(code: string): string {
    if (code == "RW") return "RBC-2024";
    if (code == "TZ") return "WHO-2024";
    if (code == "KE") return "WHO-2024";
    if (code == "UG") return "WHO-2024";
    if (code == "ZM") return "WHO-2024";
    if (code == "BI") return "WHO-2024";  // teaching mode, French
    if (code == "CD") return "WHO-2024";  // teaching mode, French
    return "";
}

// Phase A: which country codes have a working clinical protocol
// (i.e., chat is allowed)? Anything that returns a protocol_id.
function countryHasProtocol(code: string): bool {
    return protocolForCountry(code).length() > 0;
}

// Phase A: the educational-mode caveat. For non-Rwanda countries
// the canonical narrative is prepended with one sentence reminding
// the CHW that this is the WHO baseline and they should consult
// the national programme for clinical use. Empty string for RW
// (no caveat needed — the RW path is the actual operating protocol).
function educationalCaveat(country: string, lang: string): string {
    if (country == "RW") return "";
    const display = countryDisplayName(country, lang);
    if (lang == "rw") {
        return "[Uburyo bw'inyigisho] Ibyo mubona biva mu mabwiriza "
             + "rusange ya WHO 2024; ku gukoresha mu buvuzi muri "
             + display + ", reba amabwiriza y'igihugu y'igenamigambi "
             + "yo kurwanya malariya.";
    }
    return "[Teaching mode] Content shown is the WHO Global Malaria "
         + "Programme baseline (2024); for clinical use in "
         + display + ", consult the national malaria control "
         + "programme guidelines.";
}

function countryDisplayName(code: string, lang: string): string {
    if (lang == "rw") {
        if (code == "RW") return "u Rwanda";
        if (code == "BI") return "Uburundi";
        if (code == "CD") return "Repubulika Iharanira Demokarasi ya Kongo";
        if (code == "KE") return "Kenya";
        if (code == "TZ") return "Tanzaniya";
        if (code == "UG") return "Uganda";
        if (code == "ZM") return "Zambiya";
        return code;
    }
    if (lang == "sw") {
        if (code == "RW") return "Rwanda";
        if (code == "BI") return "Burundi";
        if (code == "CD") return "Jamhuri ya Kidemokrasia ya Kongo";
        if (code == "KE") return "Kenya";
        if (code == "TZ") return "Tanzania";
        if (code == "UG") return "Uganda";
        if (code == "ZM") return "Zambia";
        return code;
    }
    if (lang == "fr") {
        if (code == "RW") return "Rwanda";
        if (code == "BI") return "Burundi";
        if (code == "CD") return "République Démocratique du Congo";
        if (code == "KE") return "Kenya";
        if (code == "TZ") return "Tanzanie";
        if (code == "UG") return "Ouganda";
        if (code == "ZM") return "Zambie";
        return code;
    }
    if (code == "RW") return "Rwanda";
    if (code == "BI") return "Burundi";
    if (code == "CD") return "DRC";
    if (code == "KE") return "Kenya";
    if (code == "TZ") return "Tanzania";
    if (code == "UG") return "Uganda";
    if (code == "ZM") return "Zambia";
    return code;
}

function countryNotSupportedMessage(code: string, lang: string): string {
    // All seven malariaChat countries (RW + TZ/KE/UG/ZM teaching +
    // BI/CD French) are now supported. This function is retained as
    // a defensive default for any future unknown country code.
    const display = countryDisplayName(code, lang);
    if (lang == "rw") {
        return "MalariaChat ntibemera igihugu cy'" + display + ". "
             + "Hindura igihugu mu rutonde rw'igenamiterere "
             + "(akamenyetso ko hasi ibumoso).";
    }
    if (lang == "sw") {
        return "MalariaChat haisaidii " + display + ". Badilisha "
             + "nchi katika Mipangilio (alama ya gia, kushoto chini).";
    }
    if (lang == "fr") {
        return "MalariaChat ne prend pas en charge le pays "
             + display + ". Changez de pays dans Paramètres "
             + "(icône d'engrenage, en bas à gauche).";
    }
    return "MalariaChat does not support the country " + display
         + ". Switch the country in Settings (gear icon, "
         + "bottom-left).";
}

// ── chatHandler ─────────────────────────────────────────────────────────────

function chatHandler(req: ptr, res: ptr): void {
    counter_inc(slotChat());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }

    // Parse request JSON.
    const message     = jsonExtractString(raw, "message");
    if (message.length() == 0) {
        const errOut = "{\"task\":\"chat\","
                     + "\"error\":\"Missing 'message' field in request body.\","
                     + "\"auditId\":\"" + auditId + "\"}";
        jsonResponse(res, 400, auditId, errOut);
        return;
    }
    const langRaw     = jsonExtractString(raw, "lang");
    let lang: string;
    if      (langRaw == "rw") lang = "rw";
    else if (langRaw == "sw") lang = "sw";
    else if (langRaw == "fr") lang = "fr";
    else                       lang = "en";
    const districtReq = jsonExtractString(raw, "district");
    const reqConvId   = jsonExtractString(raw, "conversationId");
    const userNameReq = jsonExtractString(raw, "userName");
    const emailReq    = jsonExtractString(raw, "email");
    const phoneReq    = jsonExtractString(raw, "phone");
    let   countryReq  = jsonExtractString(raw, "country");
    if (countryReq.length() == 0) countryReq = "RW";
    if (!isAllowedCountryCode(countryReq)) {
        // Unknown country code from the client — reject as bad request
        // rather than silently coerce to RW; an unknown code probably
        // means a UI bug we want to surface.
        const errOut = "{\"task\":\"chat\","
                     + "\"error\":\"Invalid country code: "
                     + jsonEscape(countryReq) + "\","
                     + "\"auditId\":\"" + auditId + "\"}";
        jsonResponse(res, 400, auditId, errOut);
        return;
    }
    if (!countryHasProtocol(countryReq)) {
        // Country gating short-circuit. Phase A enables RW + TZ + KE
        // (TZ/KE on the WHO-2024 teaching baseline); the remaining
        // codes (BI/CD/UG/ZM) stay blocked here. We do NOT create a
        // chat conversation row and do NOT call the LLM. The audit
        // log still records the attempt via auditAppend below.
        auditAppend(auditId, "chat", lang, "[country-not-supported: " + countryReq + "]");
        const msg = countryNotSupportedMessage(countryReq, lang);
        const respBody = "{"
            + "\"task\":\"chat\","
            + "\"conversationId\":\"\","
            + "\"lang\":\""           + lang + "\","
            + "\"intent\":\"country-not-supported\","
            + "\"country\":\""        + countryReq + "\","
            + "\"assistantText\":\""  + jsonEscape(msg) + "\","
            + "\"structured\":null,"
            + "\"structuredEndpoint\":null,"
            + "\"llmOnline\":true,"
            + "\"auditId\":\""        + auditId + "\","
            + "\"reviewBanner\":\""   + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, respBody);
        return;
    }

    // Normalise message for downstream processing. Clinical detection and
    // routing run on the NON-scrubbed text so PHI redaction never blanks a
    // danger keyword; scrubPHI is applied only where text is persisted or
    // echoed (audit log, conversation store, LLM backend).
    const body    = normaliseBody(message);
    const scrubbed = scrubPHI(body);
    auditAppend(auditId, "chat", lang, scrubbed);
    const lower = body.toLowerCase();

    // Resolve conversation (lookup / 3h auto-close / create).
    const convId = chatGetOrCreateConversation(reqConvId, lang, districtReq,
                                               userNameReq, countryReq,
                                               emailReq, phoneReq);

    // Reconstruct PRIOR history (before persisting the current user
    // turn) so llmChat receives exactly what came before. The current
    // turn's body is passed to llmChat as the userMessage arg —
    // appending it via history would double-count.
    const historyTrimmed = chatReconstructHistory(convId, 20);

    // Persist the user turn AFTER we have a clean prior-history
    // snapshot. Subsequent queries will see this turn.
    chatPersistMessage(convId, "user", scrubbed, "", "", "", auditId);

    // Classify intent and resolve district.
    const intent = classifyChatIntent(lower, lang);
    let district = districtReq;
    if (district.length() == 0) district = chatGetConversationDistrict(convId);
    if (district.length() == 0) district = parseDistrict(lower);

    // Route to doX (clinical) or fall through to open Q&A.
    let structuredJson:     string = "";
    let structuredEndpoint: string = "";
    if (intent == "danger") {
        const out          = doDanger(countryReq, lang, body, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/danger";
    } else if (intent == "pregnancy") {
        const out          = doPregnancy(countryReq, district, lang, body, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/pregnancy";
    } else if (intent == "dose") {
        const out          = doAssess(countryReq, district, lang, body, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/assess";
    } else if (intent == "first-line") {
        const out          = doFirstLine(countryReq, district, lang, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/first-line";
    } else if (intent == "iptp") {
        const out          = doIptp(countryReq, lang, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/iptp";
    } else if (intent == "vaccines") {
        const out          = doVaccines(countryReq, lang, auditId);
        structuredJson     = doxBody(out);
        structuredEndpoint = "/v1/vaccines";
    }

    // Generate the conversational reply.
    let assistantText: string = "";
    let llmOnlineFlag: bool   = true;
    if (intent == "open") {
        const sys = chatOpenQAPrompt(countryReq, lang);
        assistantText = llmChat(sys, historyTrimmed, scrubbed, configMaxTokens());
        if (assistantText.length() == 0) {
            llmOnlineFlag = false;
            assistantText = chatOfflineFallback(lang);
        }
    } else {
        const sysBase = chatWrapClinicalPrompt(countryReq, lang);
        const llmJson = chatStripReviewBanner(structuredJson);
        const sysFull = sysBase + "\n\nTHE STRUCTURED RESULT FOR THIS TURN:\n"
                                + llmJson;
        assistantText = llmChat(sysFull, historyTrimmed, scrubbed, configMaxTokens());
        if (assistantText.length() == 0) {
            llmOnlineFlag = false;
            // Fall back to the bare deterministic narrative.
            const narr = chatNarrativeFallback(structuredJson);
            if (narr.length() > 0) {
                assistantText = narr;
            } else {
                // No narrative field (iptp/vaccines/first-line metadata);
                // give a generic acknowledgement.
                assistantText = lang == "rw"
                    ? "Igisubizo cy'amakuru cyatanzwe (LLM ntiboneka). Reba 'structured' kuri uku kuvugana."
                    : "Structured response generated (LLM unavailable). See the 'structured' field on this turn.";
            }
        }
    }

    // Phase A polish: cite WHO 2024 (not RBC 2024) for non-Rwanda
    // countries. Many narrative prose helpers (severeMalariaReferral,
    // assessProseEn, pregnancyProse{Rw,En}, treatmentFailureProse{Rw,
    // En}) embed "RBC 2024" in their text — correct for Rwanda
    // production, misleading for the WHO 2024 teaching baseline used
    // by TZ/KE/UG/ZM (and BI/CD). A surgical string substitution at
    // the response layer is the minimum-invasive Phase A fix; threading
    // a citation token through every prose helper is a Phase B
    // follow-up (item 6 in the punch list).
    if (countryReq != "RW") {
        // 1. Protocol-name cleanup: RBC → WHO. Run the longest
        // string first so we don't double-process.
        assistantText = assistantText.replace("RBC 2024", "WHO 2024");
        assistantText = assistantText.replace("RBC bulletin", "WHO bulletin");
        assistantText = assistantText.replace("RBC guidelines", "WHO guidelines");
        assistantText = assistantText.replace("RBC table", "WHO table");
        assistantText = assistantText.replace("amabwiriza ya RBC", "amabwiriza ya WHO");
        assistantText = assistantText.replace("imbonerahamwe ya RBC", "imbonerahamwe ya WHO");
        // Any remaining standalone "RBC" → "WHO". After the longer
        // forms above this catches things like "the RBC", "per RBC".
        assistantText = assistantText.replace("RBC", "WHO");

        // 2. Referral hospital naming. Burundi has no "districts", so the
        // hospital compound runs before the country-specific
        // district→commune/territoire substitutions below so we don't
        // produce awkward "hôpital de commune".
        assistantText = assistantText.replace("district hospital", "referral hospital");
        assistantText = assistantText.replace("District hospital", "Referral hospital");
        assistantText = assistantText.replace("hôpital de district", "hôpital de référence");
        assistantText = assistantText.replace("hospitali ya wilaya", "hospitali ya rufaa");
        assistantText = assistantText.replace("the district hospital", "the referral hospital");

        // 3. CHW name de-Rwanda-ification: eliminate Rwanda-specific
        // terminology for non-RW responses.
        // "Inshuti y'Ubuzima" / "Inshuti z'Ubuzima" is the Rwanda
        // CHW network name. For non-RW responses, generic "CHW" /
        // "CHWs" is correct.
        assistantText = assistantText.replace("Inshuti z'Ubuzima", "CHWs");
        assistantText = assistantText.replace("Inshuti y'Ubuzima", "CHW");
        assistantText = assistantText.replace("inshuti z'ubuzima", "CHWs");
        assistantText = assistantText.replace("inshuti y'ubuzima", "CHW");
        // RW-style salutation that occasionally leaks (despite rule 8)
        assistantText = assistantText.replace("Nshuti z'Ubuzima,", "Health worker,");
        assistantText = assistantText.replace("Nshuti z'Ubuzima", "CHWs");

        // 4. MFT terminology is a Rwanda policy (Multiple First-Line
        // Therapy with district→group rotation). The teaching
        // baseline doesn't use it. Generic substitutions:
        assistantText = assistantText.replace("Multiple First-Line Therapy", "the national first-line antimalarial");
        assistantText = assistantText.replace("MFT rotation", "first-line antimalarial");
        assistantText = assistantText.replace("MFT group", "first-line antimalarial");
        assistantText = assistantText.replace("MFT (Multiple First-Line Therapy)", "the national first-line antimalarial");
        // Standalone "MFT" — last to avoid double-touching the
        // expanded forms above.
        assistantText = assistantText.replace("MFT ", "first-line antimalarial ");

        // 5. Country-name de-leakage. The LLM sometimes says "in
        // Rwanda's protocol", "in Rwanda", etc. Replace with the
        // user's actual country.
        const userCountryName = countryDisplayName(countryReq, lang);
        assistantText = assistantText.replace("in Rwanda's", "in " + userCountryName + "'s");
        assistantText = assistantText.replace("in Rwanda", "in " + userCountryName);
        assistantText = assistantText.replace("Rwanda's", userCountryName + "'s");
        assistantText = assistantText.replace("mu Rwanda", "muri " + userCountryName);
        assistantText = assistantText.replace("au Rwanda", "en " + userCountryName);

        // 6. MOPDD (Rwanda Ministry of Public Health Disease Control)
        // reference. Strip — it's not relevant to non-RW.
        assistantText = assistantText.replace("MOPDD / RBC", "WHO");
        assistantText = assistantText.replace("MOPDD", "");
    }
    // Country-specific admin-unit substitution. After the hospital-
    // name swaps above (which replace "hôpital de district" with
    // "hôpital de référence" so we don't produce awkward
    // "hôpital de commune" / "hôpital de territoire"), any remaining
    // standalone "district" references in the prose get replaced
    // with the appropriate local term:
    //   - Burundi  → `commune`
    //   - DRC      → `territoire`
    if (countryReq == "BI") {
        assistantText = assistantText.replace("district", "commune");
        assistantText = assistantText.replace("District", "Commune");
    }
    if (countryReq == "CD") {
        assistantText = assistantText.replace("district", "territoire");
        assistantText = assistantText.replace("District", "Territoire");
    }

    // Phase A: when responding in French (BI/CD), translate the
    // English replacement tokens that the non-RW substitutions above
    // left behind, otherwise French responses would contain English
    // fragments mid-sentence ("CHW", "the national first-line
    // antimalarial"). French replacements are native-speaker reviewed.
    //
    // Order matters: longer phrases first so the "first-line
    // antimalarial" replacement doesn't partially consume the
    // "the national first-line antimalarial" form.
    if (lang == "fr") {
        assistantText = assistantText.replace("the national first-line antimalarial", "l'antipaludique national de premier plan");
        assistantText = assistantText.replace("national first-line antimalarial", "antipaludique national de premier plan");
        assistantText = assistantText.replace("first-line antimalarial", "antipaludique de première ligne");
        assistantText = assistantText.replace("CHWs", "Agents de santé communautaire");
        assistantText = assistantText.replace("CHW", "Agent de santé communautaire");
    }

    // Persist the BARE assistant turn — WITHOUT the caveat prefix.
    // When persisted text contains the caveat, the LLM would see it in
    // conversation history on the next
    // turn and replays a stale-country caveat alongside the new one
    // (e.g. user starts in BI, switches to CD, the next response had
    // both a Burundi caveat AND an RDC caveat). Keeping persisted
    // history caveat-free means the LLM never sees past caveats and
    // so can't mimic them. The caveat is then prepended below for the
    // current response only.
    chatPersistMessage(convId, "assistant", assistantText, intent,
                       structuredJson, structuredEndpoint, auditId);

    // Teaching-mode caveat — server-side prepend.
    // Previously the LLM was asked to emit the caveat via the system
    // prompt; it was observed substituting the country name (e.g. writing
    // "Tanzania" for a Zambia user) and
    // sometimes skipping the caveat entirely (severe-malaria path).
    // Prepending here, after the persist, guarantees the caveat is
    // exactly right for the CURRENT country/lang and that future
    // turns' LLM history is caveat-free.
    const caveatPrefix = educationalCaveat(countryReq, lang);
    if (caveatPrefix.length() > 0) {
        assistantText = caveatPrefix + "\n\n" + assistantText;
    }

    // Build response.
    const structuredField = structuredJson.length() > 0
        ? "\"structured\":" + structuredJson
        : "\"structured\":null";
    const structuredEndpointField = structuredEndpoint.length() > 0
        ? "\"structuredEndpoint\":\"" + structuredEndpoint + "\""
        : "\"structuredEndpoint\":null";

    const respBody = "{"
        + "\"task\":\"chat\","
        + "\"conversationId\":\""  + convId + "\","
        + "\"lang\":\""            + lang + "\","
        + "\"intent\":\""          + intent + "\","
        + "\"assistantText\":\""   + jsonEscape(assistantText) + "\","
        + structuredField + ","
        + structuredEndpointField + ","
        + "\"llmOnline\":"         + (llmOnlineFlag ? "true" : "false") + ","
        + "\"auditId\":\""         + auditId + "\","
        + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
        + "}";
    jsonResponse(res, 200, auditId, respBody);
}

// ── Chat history endpoints (chats sidebar) ──────────────────────────────────
//
// Two read-only GET endpoints back the chats-sidebar UI:
//
//   GET /v1/chats?email=<addr>     — list this user's conversations,
//                                    most-recent-first, with title
//                                    (first user message) and message count.
//   GET /v1/chat-history?conversationId=<id>
//                                  — full message history for one
//                                    conversation, ordered by created_at,
//                                    in a shape the client's bubble
//                                    renderers can replay verbatim.
//
// Email is the natural "who am I" key today (no auth, anonymous-by-
// default chat rows). When email is absent we return 400 — the client
// already gates this by checking settings.email before fetching.

function chatsListHandler(req: ptr, res: ptr): void {
    const auditId = generateAuditId();
    const email   = request_query(req, "email");
    if (email.length() == 0) {
        const errOut = "{\"task\":\"chats\","
                     + "\"error\":\"Missing 'email' query parameter.\","
                     + "\"auditId\":\"" + auditId + "\"}";
        jsonResponse(res, 400, auditId, errOut);
        return;
    }
    // Optional country filter — if present, scope the chats list to
    // that country only. This matches the per-country teaching-mode
    // mental model (RW chats and KE chats stay separate in the
    // sidebar, even when both belong to the same email).
    const countryFilter = request_query(req, "country");
    let whereCountry: string = "";
    if (countryFilter.length() > 0) {
        whereCountry = "  AND c.country = '" + sqlEscape(countryFilter) + "' ";
    }

    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT c.conversation_id, "
      + "       to_char(c.last_activity_at, 'YYYY-MM-DD\"T\"HH24:MI:SS'), "
      + "       c.lang, "
      + "       COALESCE(c.district, ''), "
      + "       c.country, "
      + "       COALESCE((SELECT m.text FROM chat_messages m "
      + "                 WHERE m.conversation_id = c.conversation_id "
      + "                   AND m.role = 'user' "
      + "                 ORDER BY m.created_at ASC LIMIT 1), ''), "
      + "       (SELECT COUNT(*) FROM chat_messages m "
      + "        WHERE m.conversation_id = c.conversation_id) "
      + "FROM chat_conversations c "
      + "WHERE c.email = '" + sqlEscape(email) + "' "
      +        whereCountry
      + "ORDER BY c.last_activity_at DESC "
      + "LIMIT 50");
    const n: i64 = dbResultRowCount(r);

    let json: string = "{\"chats\":[";
    let i: i64 = 0;
    while (i < n) {
        const cid:     string = dbResultGet(r, i, 0);
        const ts:      string = dbResultGet(r, i, 1);
        const cLang:   string = dbResultGet(r, i, 2);
        const dist:    string = dbResultGet(r, i, 3);
        const cCountry:string = dbResultGet(r, i, 4);
        const title:   string = dbResultGet(r, i, 5);
        const mcnt:    string = dbResultGet(r, i, 6);
        if (i > 0) json = json + ",";
        json = json + "{\"conversationId\":\"" + jsonEscape(cid) + "\","
                    + "\"lastActivityAt\":\""  + ts + "\","
                    + "\"lang\":\""            + cLang + "\","
                    + "\"district\":\""        + jsonEscape(dist) + "\","
                    + "\"country\":\""         + jsonEscape(cCountry) + "\","
                    + "\"title\":\""           + jsonEscape(title) + "\","
                    + "\"messageCount\":"      + mcnt + "}";
        i = i + 1;
    }
    json = json + "],\"auditId\":\"" + auditId + "\"}";
    dbDisconnect(db);
    jsonResponse(res, 200, auditId, json);
}

function chatMessagesHandler(req: ptr, res: ptr): void {
    const auditId = generateAuditId();
    const convId  = request_query(req, "conversationId");
    if (convId.length() == 0) {
        const errOut = "{\"task\":\"chat-history\","
                     + "\"error\":\"Missing 'conversationId' query parameter.\","
                     + "\"auditId\":\"" + auditId + "\"}";
        jsonResponse(res, 400, auditId, errOut);
        return;
    }

    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT role, text, "
      + "       COALESCE(intent, ''), "
      + "       COALESCE(structured_json, ''), "
      + "       COALESCE(structured_endpoint, '') "
      + "FROM chat_messages "
      + "WHERE conversation_id = '" + sqlEscape(convId) + "' "
      + "  AND role IN ('user', 'assistant') "
      + "ORDER BY created_at ASC");
    const n: i64 = dbResultRowCount(r);

    let json: string = "{\"conversationId\":\"" + jsonEscape(convId)
                     + "\",\"messages\":[";
    let i: i64 = 0;
    while (i < n) {
        const role:   string = dbResultGet(r, i, 0);
        const text:   string = dbResultGet(r, i, 1);
        const intent: string = dbResultGet(r, i, 2);
        // structured_json is already a JSON object string — embed raw,
        // do not double-escape. Empty string → JSON null.
        const sjson:  string = dbResultGet(r, i, 3);
        const sep:    string = dbResultGet(r, i, 4);
        if (i > 0) json = json + ",";
        const structuredField = sjson.length() > 0
            ? "\"structured\":" + sjson
            : "\"structured\":null";
        const sepField = sep.length() > 0
            ? "\"structuredEndpoint\":\"" + jsonEscape(sep) + "\""
            : "\"structuredEndpoint\":null";
        json = json + "{\"role\":\""   + role + "\","
                    + "\"text\":\""    + jsonEscape(text) + "\","
                    + "\"intent\":\""  + jsonEscape(intent) + "\","
                    + structuredField + ","
                    + sepField + "}";
        i = i + 1;
    }
    json = json + "],\"auditId\":\"" + auditId + "\"}";
    dbDisconnect(db);
    jsonResponse(res, 200, auditId, json);
}

function metricsHandler(req: ptr, res: ptr): void {
    const auditId = generateAuditId();
    const body = "{"
        + "\"counters\":{"
        +   "\"assess\":"            + counter_get(slotAssess())     + ","
        +   "\"danger\":"            + counter_get(slotDanger())     + ","
        +   "\"pregnancy\":"         + counter_get(slotPregnancy())  + ","
        +   "\"prevention\":"        + counter_get(slotPrevention()) + ","
        +   "\"report\":"            + counter_get(slotReport())     + ","
        +   "\"firstLine\":"         + counter_get(slotFirstLine())  + ","
        +   "\"iptp\":"              + counter_get(slotIptp())       + ","
        +   "\"vaccines\":"          + counter_get(slotVaccines())   + ","
        +   "\"chat\":"              + counter_get(slotChat())       + ","
        +   "\"severeGateTriggered\":" + counter_get(slotSevereGate())
        + "},"
        + "\"countersSource\":\"runtime:abe_counter (atomic per-process)\","
        + "\"auditId\":\"" + auditId + "\""
        + "}";
    jsonResponse(res, 200, auditId, body);
}

// /v1/assess — RDT result + weight (caller sends "RDT positive 22kg child" etc.)
// doAssess — pure function for /v1/assess. district may be empty
// (the function falls back to parseDistrict on the body, then
// defaults to Group A). body is the already-normalised input;
// doAssess does the toLowerCase. Returns "NNN{json...}".
function doAssess(country: string, district: string, lang: string, body: string, auditId: string): string {
    // Phase A: country parameter is consumed by chatHandler to inject
    // the educationalCaveat into the narrative for non-RW countries.
    // Internal SQL queries still hit RBC-2024 (WHO-2024 rows are
    // identical clones — see schema/09_who_baseline.sql); deepening
    // protocol_id routing per country is a Phase B follow-up.
    const lower = body.toLowerCase();

    // Severe-malaria gate runs before any LLM call.
    const dangerHits = dangerHitCount(lower, lang);
    if (dangerHits > 0) {
        counter_inc(slotSevereGate());
        return "200{"
             + "\"task\":\"assess\","
             + "\"language\":\""        + lang + "\","
             + "\"severeGate\":true,"
             + "\"dangerSignHits\":"    + dangerHits + ","
             + "\"action\":\"REFER_IMMEDIATELY\","
             + "\"narrative\":\""       + jsonEscape(severeMalariaReferral(lang)) + "\","
             + "\"narrativeSource\":\"deterministic:rbc-2024-severe-gate\","
             + "\"auditId\":\""         + auditId + "\","
             + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
             + "}";
    }

    // Treatment-failure short-circuit. If the CHW notes describe a
    // post-AL day-3 failure pattern, never recommend a dose — the RBC
    // 2024 protocol is "refer, do not repeat AL". This runs before the
    // dose lookup so a weight in the same text doesn't get us back into
    // AL band logic.
    if (treatmentFailureDetected(lower)) {
        const tfNarr = lang == "rw" ? treatmentFailureProseRw() : treatmentFailureProseEn();
        return "200{"
             + "\"task\":\"assess\","
             + "\"language\":\""        + lang + "\","
             + "\"severeGate\":false,"
             + "\"treatmentFailure\":true,"
             + "\"action\":\"REFER\","
             + "\"narrative\":\""       + jsonEscape(tfNarr) + "\","
             + "\"narrativeSource\":\"deterministic:rbc-2024-treatment-failure\","
             + "\"auditId\":\""         + auditId + "\","
             + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
             + "}";
    }

    // Pregnancy check before dose lookup. RBC 2024: 1st-trimester
    // pregnancy is a quinine indication (NOT AL). If we detect pregnancy
    // markers, reroute to pregnancy logic so the patient gets the
    // correct trimester-aware recommendation.
    if (isPregnant(lower)) {
        const weeksP = parseGestationalWeeks(lower);
        let trimP:     i64    = 0;
        let detTreatP: string = "";
        if (weeksP > 0) {
            const db = dbConnect("dbname=malariachat");
            const sql = "SELECT trimester, treatment_en, treatment_rw "
                      + "FROM trimester_rules "
                      + "WHERE protocol_id = 'RBC-2024' "
                      + "  AND " + weeksP + " BETWEEN weeks_min AND COALESCE(weeks_max, 999) "
                      + "LIMIT 1";
            const r = dbQuery(db, sql);
            const trimStr:  string = dbResultGet(r, 0, 0);
            const treatEnP: string = dbResultGet(r, 0, 1);
            const treatRwP: string = dbResultGet(r, 0, 2);
            dbDisconnect(db);
            if (trimStr.length() == 0) {
                return "500{\"task\":\"assess\",\"reroute\":\"pregnancy\","
                     + "\"error\":\"trimester_rules lookup failed (DB unreachable or no row)\","
                     + "\"auditId\":\"" + auditId + "\""
                     + "}";
            }
            trimP     = Number(trimStr) as i64;
            detTreatP = lang == "rw" ? treatRwP : treatEnP;
        }
        const havePregT = trimP > 0;
        const pregNarr = havePregT
            ? (lang == "rw" ? pregnancyProseRw(weeksP, trimP) : pregnancyProseEn(weeksP, trimP))
            : (lang == "rw" ? pregnancyProseNoWeeksRw() : pregnancyProseNoWeeksEn());
        const verifiedT = havePregT
            ? ("{\"weeks\":" + weeksP + ",\"trimester\":" + trimP
               + ",\"treatment\":\"" + jsonEscape(detTreatP) + "\"}")
            : "null";
        const iptpJson = iptpJsonForTrimester(trimP, lang);
        let preDistrict = district;
        if (preDistrict.length() == 0) {
            preDistrict = parseDistrict(lower);
        }
        const mftJsonP = mftPregnancyJson(preDistrict, trimP, lang);
        return "200{"
             + "\"task\":\"assess\","
             + "\"reroute\":\"pregnancy\","
             + "\"language\":\""           + lang + "\","
             + "\"severeGate\":false,"
             + "\"narrative\":\""          + jsonEscape(pregNarr) + "\","
             + "\"narrativeSource\":\"deterministic:rbc-2024-pregnancy-route\","
             + "\"verifiedTrimester\":"    + verifiedT + ","
             + "\"verifiedTrimesterSource\":\"deterministic:rbc-2024-trimester-table\","
             + "\"iptp\":"                 + iptpJson + ","
             + "\"iptpSource\":\"deterministic:rbc-2024-iptp-protocol\","
             + "\"mftAware\":"             + mftJsonP + ","
             + "\"mftAwareSource\":\"deterministic:rbc-2024-mft-district-group-rotation\","
             + "\"auditId\":\""            + auditId + "\","
             + "\"reviewBanner\":\""       + jsonEscape(reviewBanner()) + "\""
             + "}";
    }

    // MFT district resolution. District passed in may be empty (caller
    // didn't get one from ?district=); fall back to body parse, then
    // default to Group A. Unknown but non-empty district → 400.
    let resolvedDistrict = district;
    if (resolvedDistrict.length() == 0) {
        resolvedDistrict = parseDistrict(lower);
    }

    const dbR = dbConnect("dbname=malariachat");
    let districtName:    string = "";
    let province:        string = "";
    let mftGroup:        string = "";
    let mftCtxSource:    string = "";
    if (resolvedDistrict.length() > 0) {
        const rR = dbQuery(dbR,
            "SELECT name, province, mft_group FROM districts ORDER BY name");
        const nR: i64 = dbResultRowCount(rR);
        const districtLower = resolvedDistrict.toLowerCase();
        for (let i: i64 = 0; i < nR; i = i + 1) {
            const nm: string = dbResultGet(rR, i, 0);
            if (nm.toLowerCase() == districtLower) {
                districtName = nm;
                province     = dbResultGet(rR, i, 1);
                mftGroup     = dbResultGet(rR, i, 2);
                break;
            }
        }
        if (districtName.length() == 0) {
            dbDisconnect(dbR);
            return "400{"
                 + "\"task\":\"assess\","
                 + "\"error\":\"Unknown district '" + jsonEscape(resolvedDistrict) + "'. Rwanda has 30 districts; check spelling.\","
                 + "\"auditId\":\""  + auditId + "\""
                 + "}";
        }
        mftCtxSource = "user-supplied-district";
    } else {
        mftGroup     = "A";
        mftCtxSource = "default-group-a";
    }

    const rG = dbQuery(dbR,
        "SELECT group_letter, drug, source_note FROM mft_current_drug");
    const nG: i64 = dbResultRowCount(rG);
    let firstLineDrug:   string = "";
    let currentRotation: string = "";
    for (let i: i64 = 0; i < nG; i = i + 1) {
        const g: string = dbResultGet(rG, i, 0);
        if (g == mftGroup) {
            firstLineDrug   = dbResultGet(rG, i, 1);
            currentRotation = dbResultGet(rG, i, 2);
            break;
        }
    }
    dbDisconnect(dbR);
    if (firstLineDrug.length() == 0) {
        return "500{"
             + "\"task\":\"assess\","
             + "\"error\":\"mft_current_drug has no row for group " + mftGroup + " — rotation not configured. INSERT INTO mft_current_drug per the latest RBC bulletin.\","
             + "\"district\":\""  + districtName + "\","
             + "\"mftGroup\":\""  + mftGroup + "\","
             + "\"auditId\":\""   + auditId  + "\""
             + "}";
    }

    const kg = parseWeightKg(lower);
    const haveDeterministicDose = kg > 0.0;

    let detBand:     string = "";
    let detSchedule: string = "";
    let detTabs:     i64    = 0;

    if (haveDeterministicDose) {
        const db = dbConnect("dbname=malariachat");
        const sql = "SELECT tablets_per_dose, schedule_en, schedule_rw, "
                  + "       age_label_en, age_label_rw "
                  + "FROM antimalarial_weight_bands "
                  + "WHERE protocol_id = 'RBC-2024' "
                  + "  AND drug = '" + firstLineDrug + "' "
                  + "  AND " + (kg as i64) + " >= min_kg "
                  + "ORDER BY min_kg DESC LIMIT 1";
        const r = dbQuery(db, sql);

        const tabsStr: string = dbResultGet(r, 0, 0);
        const schedEn: string = dbResultGet(r, 0, 1);
        const schedRw: string = dbResultGet(r, 0, 2);
        const labelEn: string = dbResultGet(r, 0, 3);
        const labelRw: string = dbResultGet(r, 0, 4);
        dbDisconnect(db);

        if (tabsStr.length() == 0) {
            return "500{"
                 + "\"task\":\"assess\","
                 + "\"error\":\"antimalarial_weight_bands lookup failed for drug=" + firstLineDrug + " (DB unreachable or no row at this weight).\","
                 + "\"auditId\":\""  + auditId + "\""
                 + "}";
        }

        detTabs     = Number(tabsStr) as i64;
        detSchedule = lang == "rw" ? schedRw : schedEn;
        detBand     = lang == "rw" ? labelRw : labelEn;
    }

    let narrative: string = "";
    let source:    string = "";
    if (haveDeterministicDose) {
        narrative = lang == "rw"
            ? assessProseRw(kg, firstLineDrug, detBand, detSchedule)
            : assessProseEn(kg, firstLineDrug, detBand, detSchedule);
        source = "deterministic:rbc-2024-prose-template";
    } else {
        narrative = lang == "rw" ? assessProseNoWeightRw() : assessProseNoWeightEn();
        source = "deterministic:rbc-2024-no-weight-prompt";
    }

    const verified = haveDeterministicDose
        ? ("{\"weightKg\":" + (kg as i64) + ",\"drug\":\"" + jsonEscape(firstLineDrug)
           + "\",\"band\":\"" + jsonEscape(detBand) + "\",\"tablets\":" + detTabs
           + ",\"schedule\":\"" + jsonEscape(detSchedule) + "\"}")
        : "null";

    const districtField = districtName.length() > 0
        ? "\"district\":\"" + jsonEscape(districtName) + "\""
        : "\"district\":null";
    const provinceField = province.length() > 0
        ? "\"province\":\"" + jsonEscape(province) + "\""
        : "\"province\":null";
    return "200{"
         + "\"task\":\"assess\","
         + "\"language\":\""           + lang + "\","
         + districtField + ","
         + provinceField + ","
         + "\"mftGroup\":\""           + jsonEscape(mftGroup) + "\","
         + "\"mftContextSource\":\""   + jsonEscape(mftCtxSource) + "\","
         + "\"firstLineDrug\":\""      + jsonEscape(firstLineDrug) + "\","
         + "\"severeGate\":false,"
         + "\"narrative\":\""          + jsonEscape(narrative) + "\","
         + "\"narrativeSource\":\""    + source + "\","
         + "\"verifiedDose\":"         + verified + ","
         + "\"verifiedDoseSource\":\"deterministic:rbc-2024-antimalarial-weight-bands\","
         + "\"currentRotationSource\":\"" + jsonEscape(currentRotation) + "\","
         + "\"auditId\":\""            + jsonEscape(auditId) + "\","
         + "\"reviewBanner\":\""       + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function assessHandler(req: ptr, res: ptr): void {
    counter_inc(slotAssess());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }
    const lang    = langFromQuery(req);
    // Detection runs on the non-scrubbed body; scrubPHI is applied only to
    // the text we persist to the audit log.
    const body    = normaliseBody(raw);
    auditAppend(auditId, "assess", lang, scrubPHI(body));
    const district = districtFromQuery(req);
    const out      = doAssess("RW", district, lang, body, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

// /v1/danger — caller posts presentation text, get severity check + advice.
// doDanger — pure function for the /v1/danger response. body is the
// already-normalised (scrubPHI + normaliseBody) input; doDanger does
// the toLowerCase itself. Note: slotSevereGate counter ticks INSIDE
// doDanger because it tracks clinical-event detection, not endpoint
// hits — same count whether triggered through /v1/danger or /v1/chat.
function doDanger(country: string, lang: string, body: string, auditId: string): string {
    const lower = body.toLowerCase();
    const hits  = dangerHitCount(lower, lang);

    if (hits > 0) {
        counter_inc(slotSevereGate());
        return "200{"
             + "\"task\":\"danger\","
             + "\"language\":\""     + lang + "\","
             + "\"dangerSignHits\":" + hits + ","
             + "\"action\":\"REFER_IMMEDIATELY\","
             + "\"narrative\":\""    + jsonEscape(severeMalariaReferral(lang)) + "\","
             + "\"narrativeSource\":\"deterministic:rbc-2024-severe-gate\","
             + "\"auditId\":\""      + auditId + "\","
             + "\"reviewBanner\":\"" + jsonEscape(reviewBanner()) + "\""
             + "}";
    }

    if (treatmentFailureDetected(lower)) {
        const tfNarr = lang == "rw" ? treatmentFailureProseRw() : treatmentFailureProseEn();
        return "200{"
             + "\"task\":\"danger\","
             + "\"language\":\""        + lang + "\","
             + "\"treatmentFailure\":true,"
             + "\"action\":\"REFER\","
             + "\"narrative\":\""       + jsonEscape(tfNarr) + "\","
             + "\"narrativeSource\":\"deterministic:rbc-2024-treatment-failure\","
             + "\"auditId\":\""         + auditId + "\","
             + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
             + "}";
    }

    const narrative = lang == "rw" ? dangerNoSevereProseRw() : dangerNoSevereProseEn();
    return "200{"
         + "\"task\":\"danger\","
         + "\"language\":\""        + lang + "\","
         + "\"dangerSignHits\":0,"
         + "\"narrative\":\""       + jsonEscape(narrative) + "\","
         + "\"narrativeSource\":\"deterministic:rbc-2024-monitor-template\","
         + "\"auditId\":\""         + auditId + "\","
         + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function dangerHandler(req: ptr, res: ptr): void {
    counter_inc(slotDanger());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }
    const lang    = langFromQuery(req);
    // Detection runs on the non-scrubbed body; scrubPHI is applied only to
    // the text we persist to the audit log.
    const body    = normaliseBody(raw);
    auditAppend(auditId, "danger", lang, scrubPHI(body));
    const out     = doDanger("RW", lang, body, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

// doPregnancy — pure function for /v1/pregnancy. district may be
// empty (helper inside resolves "" and the assess→pregnancy reroute
// also calls into this same SQL pattern).
function doPregnancy(country: string, district: string, lang: string, body: string, auditId: string): string {
    const lower = body.toLowerCase();
    const weeks = parseGestationalWeeks(lower);
    let trim:     i64    = 0;
    let detTreat: string = "";
    if (weeks > 0) {
        const db = dbConnect("dbname=malariachat");
        const sql = "SELECT trimester, treatment_en, treatment_rw "
                  + "FROM trimester_rules "
                  + "WHERE protocol_id = 'RBC-2024' "
                  + "  AND " + weeks + " BETWEEN weeks_min AND COALESCE(weeks_max, 999) "
                  + "LIMIT 1";
        const r = dbQuery(db, sql);
        const trimStr: string = dbResultGet(r, 0, 0);
        const treatEn: string = dbResultGet(r, 0, 1);
        const treatRw: string = dbResultGet(r, 0, 2);
        dbDisconnect(db);
        if (trimStr.length() == 0) {
            return "500{\"task\":\"pregnancy\","
                 + "\"error\":\"trimester_rules lookup failed (DB unreachable or no row)\","
                 + "\"auditId\":\"" + auditId + "\""
                 + "}";
        }
        trim     = Number(trimStr) as i64;
        detTreat = lang == "rw" ? treatRw : treatEn;
    }
    const haveTri = trim > 0;

    let narrative: string = "";
    let source:    string = "";
    if (haveTri) {
        narrative = lang == "rw"
            ? pregnancyProseRw(weeks, trim)
            : pregnancyProseEn(weeks, trim);
        source = "deterministic:rbc-2024-prose-template";
    } else {
        narrative = lang == "rw"
            ? pregnancyProseNoWeeksRw()
            : pregnancyProseNoWeeksEn();
        source = "deterministic:rbc-2024-no-weeks-prompt";
    }

    const verified = haveTri
        ? ("{\"weeks\":" + weeks + ",\"trimester\":" + trim
           + ",\"treatment\":\"" + jsonEscape(detTreat) + "\"}")
        : "null";

    const iptpJson = iptpJsonForTrimester(trim, lang);
    // District resolution: prefer caller's hint, fall back to body parse.
    let preDistrict = district;
    if (preDistrict.length() == 0) {
        preDistrict = parseDistrict(lower);
    }
    const mftJson = mftPregnancyJson(preDistrict, trim, lang);
    return "200{"
         + "\"task\":\"pregnancy\","
         + "\"language\":\""           + lang + "\","
         + "\"narrative\":\""          + jsonEscape(narrative) + "\","
         + "\"narrativeSource\":\""    + source + "\","
         + "\"verifiedTrimester\":"    + verified + ","
         + "\"verifiedTrimesterSource\":\"deterministic:rbc-2024-trimester-table\","
         + "\"iptp\":"                 + iptpJson + ","
         + "\"iptpSource\":\"deterministic:rbc-2024-iptp-protocol\","
         + "\"mftAware\":"             + mftJson + ","
         + "\"mftAwareSource\":\"deterministic:rbc-2024-mft-district-group-rotation\","
         + "\"auditId\":\""            + auditId + "\","
         + "\"reviewBanner\":\""       + jsonEscape(reviewBanner()) + "\""
         + "}";
}

function pregnancyHandler(req: ptr, res: ptr): void {
    counter_inc(slotPregnancy());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }
    const lang    = langFromQuery(req);
    // Detection runs on the non-scrubbed body; scrubPHI is applied only to
    // the text we persist to the audit log.
    const body    = normaliseBody(raw);
    auditAppend(auditId, "pregnancy", lang, scrubPHI(body));
    const district = districtFromQuery(req);
    const out      = doPregnancy("RW", district, lang, body, auditId);
    jsonResponse(res, doxStatus(out), auditId, doxBody(out));
}

function preventionHandler(req: ptr, res: ptr): void {
    counter_inc(slotPrevention());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }
    const lang    = langFromQuery(req);
    // Intent detection runs on the non-scrubbed body; scrubPHI is applied
    // only to text that is persisted (audit) or sent to the LLM backend.
    const body    = normaliseBody(raw);
    const scrubbed = scrubPHI(body);
    auditAppend(auditId, "prevention", lang, scrubbed);
    const lower   = body.toLowerCase();

    // ITN distribution short-circuit (RW only). Claude-on-RW was
    // producing inconsistent / mangled Kinyarwanda for this preset;
    // the deterministic CHW-reviewed prose is the source of truth.
    // EN keeps going to Claude (the model's English on this topic
    // is reliable). Other prevention queries (IRS, larviciding,
    // free-form community messaging) still go to Claude regardless
    // of language.
    // Community messaging check first — its preset payload mentions
    // "inzitiramibu" which would otherwise route to the ITN template.
    if (lang == "rw" && isCommunityMessagingIntent(lower)) {
        const cmOut = "{"
            + "\"task\":\"prevention\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(preventionCommunityProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-community-messaging\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, cmOut);
        return;
    }
    // ITN-at-home check before ITN-distribution: at-home questions
    // also mention "inzitiramibu" but with a household scope marker
    // (imiryango / mu rugo / families / household). The distribution
    // detector is the catch-all and would otherwise eat this case.
    if (lang == "rw" && isItnAtHomeIntent(lower)) {
        const ahOut = "{"
            + "\"task\":\"prevention\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(preventionItnAtHomeProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-itn-at-home\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, ahOut);
        return;
    }
    if (lang == "rw" && isItnDistributionIntent(lower)) {
        const itnOut = "{"
            + "\"task\":\"prevention\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(preventionItnProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-itn-distribution\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, itnOut);
        return;
    }
    if (lang == "rw" && isIrsScheduleIntent(lower)) {
        const irsOut = "{"
            + "\"task\":\"prevention\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(preventionIrsProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-irs-schedule\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, irsOut);
        return;
    }

    const userPrompt = langTag(lang) + " Prevention question: " + scrubbed
                     + ". Cover ITN use, IRS, larviciding where relevant, "
                     + "and community-level messaging.";
    let narrative = llmChat(llmSystemPrompt(), "[]", userPrompt, configMaxTokens());
    let source = "llm:claude-haiku-4-5";
    if (narrative.length() == 0) {
        narrative = "(LLM unavailable — fall back to RBC ITN distribution guidance.)";
        source = "(unavailable)";
    }

    const out = "{"
        + "\"task\":\"prevention\","
        + "\"language\":\""        + lang + "\","
        + "\"narrative\":\""       + jsonEscape(narrative) + "\","
        + "\"narrativeSource\":\"" + source + "\","
        + "\"auditId\":\""         + auditId + "\","
        + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
        + "}";
    jsonResponse(res, 200, auditId, out);
}

function reportHandler(req: ptr, res: ptr): void {
    counter_inc(slotReport());
    const auditId = generateAuditId();
    const raw     = request_body(req);
    if (raw.length() == 0) { emptyBodyError(res, auditId); return; }
    const lang    = langFromQuery(req);
    // Intent detection runs on the non-scrubbed body; scrubPHI is applied
    // only to text that is persisted (audit) or sent to the LLM backend.
    const body    = normaliseBody(raw);
    const scrubbed = scrubPHI(body);
    auditAppend(auditId, "report", lang, scrubbed);
    const lower   = body.toLowerCase();

    // Form-completion check first — most specific marker ("ifishi"
    // / "yuzuza ifishi" / "referral form"). Doesn't overlap with the
    // other report intents.
    if (lang == "rw" && isFormCompletionReportIntent(lower)) {
        const fcOut = "{"
            + "\"task\":\"report\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(reportFormCompletionProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-form-completion\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, fcOut);
        return;
    }
    // Active-transmission check — its preset payload mentions
    // numbers + "abarwaye malariya" / "malariya ikabije" which are
    // more specific than the zero-cases markers below.
    if (lang == "rw" && isActiveTransmissionReportIntent(lower)) {
        const atOut = "{"
            + "\"task\":\"report\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(reportActiveTransmissionProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-active-transmission\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, atOut);
        return;
    }
    // Zero-case reporting deterministic short-circuit (RW only).
    // Same pattern as prevention: Claude on lang=rw was inconsistent
    // for this scenario; the template below is CHW-reviewed.
    if (lang == "rw" && isZeroCasesReportIntent(lower)) {
        const zcOut = "{"
            + "\"task\":\"report\","
            + "\"language\":\"rw\","
            + "\"narrative\":\""       + jsonEscape(reportZeroCasesProseRw()) + "\","
            + "\"narrativeSource\":\"deterministic:rbc-2024-zero-cases\","
            + "\"auditId\":\""         + auditId + "\","
            + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
            + "}";
        jsonResponse(res, 200, auditId, zcOut);
        return;
    }

    const userPrompt = langTag(lang) + " DHIS2 elimination-reporting scenario: "
                     + scrubbed
                     + ". Outline the structured fields a CHW should record "
                     + "and the escalation path for zero-case versus active "
                     + "transmission districts.";
    let narrative = llmChat(llmSystemPrompt(), "[]", userPrompt, configMaxTokens());
    let source = "llm:claude-haiku-4-5";
    if (narrative.length() == 0) {
        narrative = "(LLM unavailable — record case in DHIS2 with district, age, RDT result, treatment, and outcome at minimum.)";
        source = "(unavailable)";
    }

    const out = "{"
        + "\"task\":\"report\","
        + "\"language\":\""        + lang + "\","
        + "\"narrative\":\""       + jsonEscape(narrative) + "\","
        + "\"narrativeSource\":\"" + source + "\","
        + "\"auditId\":\""         + auditId + "\","
        + "\"reviewBanner\":\""    + jsonEscape(reviewBanner()) + "\""
        + "}";
    jsonResponse(res, 200, auditId, out);
}

// ── Server entry point ──────────────────────────────────────────────────────

function main(): i64 {
    console.log("==============================================");
    console.log("  MalariaChat Clinical API — v4.1 (CHW demo)");
    console.log("  Bilingual: English + Kinyarwanda");
    console.log("  Protocol: RBC 2024 malaria treatment guidelines");
    console.log("  Assistive tool only — NOT a substitute for clinical");
    console.log("  judgement. Synthetic / demo data only.");
    console.log("==============================================");

    const srv = server_new();
    server_port(srv, configPort());
    server_cors(srv, configCorsOrigin());

    server_get(srv,  "/",                       homeHandler);
    server_get(srv,  "/v1/health",              healthHandler);
    server_get(srv,  "/v1/metrics",             metricsHandler);
    server_get(srv,  "/v1/audit-log",           auditLogHandler);
    server_get(srv,  "/v1/explain-dose",        explainDoseHandler);
    server_get(srv,  "/v1/explain-trimester",   explainTrimesterHandler);
    server_get(srv,  "/v1/first-line",          firstLineHandler);
    server_get(srv,  "/v1/iptp",                iptpHandler);
    server_get(srv,  "/v1/vaccines",            vaccinesHandler);
    server_post(srv, "/v1/assess",              assessHandler);
    server_post(srv, "/v1/danger",              dangerHandler);
    server_post(srv, "/v1/pregnancy",           pregnancyHandler);
    server_post(srv, "/v1/prevention",          preventionHandler);
    server_post(srv, "/v1/report",              reportHandler);
    server_post(srv, "/v1/chat",                chatHandler);
    server_get(srv,  "/v1/chats",               chatsListHandler);
    server_get(srv,  "/v1/chat-history",        chatMessagesHandler);

    console.log("");
    console.log("Endpoints registered:");
    console.log("  GET  http://127.0.0.1:8444/                         (demo UI)");
    console.log("  GET  http://127.0.0.1:8444/v1/health");
    console.log("  GET  http://127.0.0.1:8444/v1/audit-log");
    console.log("  GET  http://127.0.0.1:8444/v1/explain-dose          ?lang=en|rw");
    console.log("  GET  http://127.0.0.1:8444/v1/explain-trimester     ?lang=en|rw");
    console.log("  GET  http://127.0.0.1:8444/v1/first-line            ?district=<one of 30>&lang=en|rw");
    console.log("  GET  http://127.0.0.1:8444/v1/iptp                  ?lang=en|rw");
    console.log("  GET  http://127.0.0.1:8444/v1/vaccines               ?lang=en|rw");
    console.log("  GET  http://127.0.0.1:8444/v1/metrics");
    console.log("  POST http://127.0.0.1:8444/v1/assess     ?lang=en|rw");
    console.log("  POST http://127.0.0.1:8444/v1/danger     ?lang=en|rw");
    console.log("  POST http://127.0.0.1:8444/v1/pregnancy  ?lang=en|rw");
    console.log("  POST http://127.0.0.1:8444/v1/prevention ?lang=en|rw");
    console.log("  POST http://127.0.0.1:8444/v1/report     ?lang=en|rw");
    console.log("  POST http://127.0.0.1:8444/v1/chat        (malariaChat — JSON body: {message, lang, district?, conversationId?})");
    console.log("  GET  http://127.0.0.1:8444/v1/chats        ?email=<addr>            (chats sidebar — list this user's conversations)");
    console.log("  GET  http://127.0.0.1:8444/v1/chat-history ?conversationId=<id>     (chats sidebar — message history for one conversation)");
    console.log("");
    console.log("Severe-malaria pre-check runs BEFORE every LLM call.");
    console.log("Listening...");

    server_listen(srv);
    return 0;
}
