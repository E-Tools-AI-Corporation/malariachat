// malariachat.abe — MalariaChat Clinical Support API (Abe v4.1)
//
// A deterministic malaria clinical decision-support API (RBC 2024 protocol,
// EN/RW) with an optional, pluggable LLM backend for free-form chat.
//
// Bilingual (English + Kinyarwanda) HTTP service for Inshuti z'Ubuzima
// (community health workers) and health-centre staff in Rwanda.
//
// ARCHITECTURE
// ============
//   Pre-model:  checkSevereMalaria() — sub-100ms substring scan, EN+RW.
//               If a danger sign is hit, the request short-circuits with
//               a mandatory bilingual referral message BEFORE the LLM
//               backend is ever consulted. The deterministic engine is the
//               first line of defence; the LLM backend is the second.
//   Backend:    llmChat() (llm.abe) proxies free-form chat to a
//               pluggable LLM backend with a system prompt locked to
//               RBC 2024 hard rules.
//   Post-model: PHI scrub (deterministic substring scans for @, MRN,
//               ID:, +250 phone numbers — Abe v4.1 has no regex codegen).
//
// Endpoints
//   GET  /v1/health     — liveness + model info
//   GET  /v1/metrics    — session counters
//   POST /v1/assess     — RDT result + weight → AL dose decision
//   POST /v1/danger     — presentation → danger-sign check + action
//   POST /v1/pregnancy  — pregnancy scenario → IPTp / trimester guidance
//   POST /v1/prevention — prevention question → ITN/IRS/community advice
//   POST /v1/report     — DHIS2 elimination-reporting guidance
//
// Languages
//   Pass `?lang=rw` (or `?lang=en`) on any POST. Default is `en`.
//
// Every response carries:
//   X-MalariaChat-Audit-Id     — opaque per-request ID
//   X-MalariaChat-Review-Required: true
//   reviewBanner             — physician-review note in the body
//
// E-Tools AI Corporation | v4.1 | 2026

import { llmChat } from './llm';

// ── Configuration accessors ─────────────────────────────────────────────────
// Top-level `const` is rejected by codegen (E08B0); accessor functions
// give us the same single-source-of-truth without fighting that.

function configPort():       i64    { return 8444; }
function configCorsOrigin(): string { return "*"; }
function configMaxTokens():  i64    { return 800; }   // safety ceiling for backend chat completions, not a target
function modelLabel():       string { return "MalariaChat — deterministic clinical engine; free-form chat via pluggable LLM backend"; }
function apiVersion():       string { return "4.1"; }

// ── Audit ID generator ──────────────────────────────────────────────────────
// Microsecond timestamp gives a globally-unique opaque ID without
// needing top-level mutable state (codegen rejects top-level `let`).

function generateAuditId(): string {
    return "MLW-" + time_us();
}

// ── Session metrics ─────────────────────────────────────────────────────────
// Backed by the runtime's atomic counter primitives (counter_inc,
// counter_get — see runtime/abe_bench.c). Each handler increments its
// slot at entry; the metrics endpoint reads them. Slot indices are
// assigned here as accessor functions so they're impossible to
// shadow / typo silently.

function slotAssess():     i64 { return 0; }
function slotDanger():     i64 { return 1; }
function slotPregnancy():  i64 { return 2; }
function slotPrevention(): i64 { return 3; }
function slotReport():     i64 { return 4; }
function slotSevereGate(): i64 { return 5; }
function slotFirstLine():  i64 { return 6; }
function slotIptp():       i64 { return 7; }
function slotVaccines():   i64 { return 8; }
function slotChat():       i64 { return 9; }

// ── Headers + JSON response helper ──────────────────────────────────────────

function setClinicalHeaders(res: ptr, auditId: string): void {
    response_header(res, "X-MalariaChat-Audit-Id",        auditId);
    response_header(res, "X-MalariaChat-Review-Required", "true");
    response_header(res, "X-Content-Type-Options",      "nosniff");
}

function jsonResponse(res: ptr, status: i32, auditId: string, body: string): void {
    setClinicalHeaders(res, auditId);
    response_status(res, status);
    response_json(res, body);
}

function reviewBanner(): string {
    return "[PROTOCOL_REVIEW_REQUIRED] MalariaChat is an assistive tool for "
         + "Inshuti z'Ubuzima and health-centre staff. Every response must be "
         + "reviewed against current RBC guidelines before clinical use. This "
         + "is not a substitute for trained clinical judgement.";
}

// ── JSON string escape (caller-controlled inputs land in body) ──────────────

function jsonEscape(s: string): string {
    let out = s.replace("\\", "\\\\");
    out = out.replace("\"", "\\\"");
    out = out.replace("\n", "\\n");
    out = out.replace("\r", "\\r");
    out = out.replace("\t", "\\t");
    return out;
}

// ── Empty-body and lang helpers ─────────────────────────────────────────────

function emptyBodyError(res: ptr, auditId: string): void {
    const body = "{"
        + "\"error\":\"empty body — POST the input text\","
        + "\"auditId\":\"" + auditId + "\","
        + "\"reviewBanner\":\"" + jsonEscape(reviewBanner()) + "\""
        + "}";
    jsonResponse(res, 400, auditId, body);
}

function langFromQuery(req: ptr): string {
    const q = request_query(req, "lang");
    if (q == "rw") return "rw";
    return "en";
}

// Builds the "iptp" JSON snippet that pregnancyHandler and the assess
// pregnancy reroute embed in their response when trimester >= 2.
// Returns "null" for trim < 2 (IPTp-SP is contraindicated in 1st
// trimester per the seeded contraindications row, even though
// iptp_protocol.weeks_start says 13). Soft-fail: a missing iptp_protocol
// row (e.g. DB hiccup) yields "null" rather than 500-ing the parent
// response — the trimester treatment is the main clinical info; IPTp
// is supplementary, so a null is the right honest fallback: hard-fail
// only on life-affecting data; soft-fall on supplementary data.
function iptpJsonForTrimester(trim: i64, lang: string): string {
    if (trim < 2) return "null";
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT drug, tablets_per_dose, mg_per_dose, min_doses, "
      + "       interval_weeks, contraindications_en, "
      + "       contraindications_rw, delivery "
      + "FROM iptp_protocol "
      + "WHERE protocol_id = 'RBC-2024' LIMIT 1");
    const drug: string = dbResultGet(r, 0, 0);
    if (drug.length() == 0) { dbDisconnect(db); return "null"; }
    const tabletsStr:  string = dbResultGet(r, 0, 1);
    const mgStr:       string = dbResultGet(r, 0, 2);
    const minDosesStr: string = dbResultGet(r, 0, 3);
    const intervalStr: string = dbResultGet(r, 0, 4);
    const contraEn:    string = dbResultGet(r, 0, 5);
    const contraRw:    string = dbResultGet(r, 0, 6);
    const delivery:    string = dbResultGet(r, 0, 7);
    dbDisconnect(db);
    const contra = lang == "rw" ? contraRw : contraEn;
    return "{"
         + "\"drug\":\""             + jsonEscape(drug) + "\","
         + "\"tabletsPerDose\":"     + tabletsStr + ","
         + "\"mgPerDose\":\""        + jsonEscape(mgStr) + "\","
         + "\"minDoses\":"           + minDosesStr + ","
         + "\"intervalWeeks\":"      + intervalStr + ","
         + "\"delivery\":\""         + jsonEscape(delivery) + "\","
         + "\"contraindications\":\"" + jsonEscape(contra) + "\""
         + "}";
}

// Reads ?district= and returns the raw user-supplied district name
// (trimmed). Validation against the 30 known Rwandan districts
// happens at the SQL layer (canonical name + mft_group come from
// the districts table). The handler 400s if no district matches —
// see MFT Q&A page 3 for the district→group mapping.
function districtFromQuery(req: ptr): string {
    const raw = request_query(req, "district");
    return raw.trim();
}

// Builds the "mftAware" JSON block for pregnancy responses. Given the
// patient's district + trimester, resolves: district → mft_group →
// current drug → trimester safety. If the assigned drug is
// contraindicated in this trimester (today: ASPY in T1 per Integrated
// Guidelines 2024 §1.C), surfaces the fallback drug from
// antimalarial_pregnancy_safety.
//
// Empty district → defaults to Group A (CHW sets their actual district
// to override). Non-empty but unrecognised district → returns "null"
// so the caller (e.g. assess dose path) can hard-fail on a typo.
// trim < 1 → returns "null" (no safety question to answer). A missing
// mft_current_drug row also returns "null".
//
// mftContextSource discriminates the two valid cases in the response:
//   "default-group-a"        — no district was provided
//   "user-supplied-district" — district resolved
function mftPregnancyJson(district: string, trim: i64, lang: string): string {
    if (trim < 1) return "null";
    const db = dbConnect("dbname=malariachat");

    let canonical: string = "";
    let mftGroup:  string = "";
    let isDefault: bool   = false;

    if (district.length() == 0) {
        // No district supplied — default to Group A.
        mftGroup  = "A";
        isDefault = true;
    } else {
        // Resolve district → mft_group (case-insensitive).
        const rD = dbQuery(db,
            "SELECT name, mft_group FROM districts ORDER BY name");
        const nD: i64 = dbResultRowCount(rD);
        const dLower = district.toLowerCase();
        for (let i: i64 = 0; i < nD; i = i + 1) {
            const nm: string = dbResultGet(rD, i, 0);
            if (nm.toLowerCase() == dLower) {
                canonical = nm;
                mftGroup  = dbResultGet(rD, i, 1);
                break;
            }
        }
        if (mftGroup.length() == 0) {
            // District provided but doesn't resolve — caller should
            // already have rejected this as a typo. Return null
            // defensively.
            dbDisconnect(db);
            return "null";
        }
    }

    // 2. mft_group → current drug
    const rG = dbQuery(db,
        "SELECT group_letter, drug FROM mft_current_drug");
    const nG: i64 = dbResultRowCount(rG);
    let currentDrug: string = "";
    for (let i: i64 = 0; i < nG; i = i + 1) {
        if (dbResultGet(rG, i, 0) == mftGroup) {
            currentDrug = dbResultGet(rG, i, 1);
            break;
        }
    }
    if (currentDrug.length() == 0) { dbDisconnect(db); return "null"; }

    // 3. drug + trimester → safety + fallback
    const rS = dbQuery(db,
        "SELECT drug, trimester_1_allowed, trimester_2_allowed, "
      + "       trimester_3_allowed, fallback_drug "
      + "FROM antimalarial_pregnancy_safety");
    const nS: i64 = dbResultRowCount(rS);
    let allowed:  string = "";
    let fallback: string = "";
    for (let i: i64 = 0; i < nS; i = i + 1) {
        if (dbResultGet(rS, i, 0) == currentDrug) {
            if (trim == 1)      allowed = dbResultGet(rS, i, 1);
            else if (trim == 2) allowed = dbResultGet(rS, i, 2);
            else                allowed = dbResultGet(rS, i, 3);
            fallback = dbResultGet(rS, i, 4);
            break;
        }
    }
    dbDisconnect(db);

    const isAllowed   = allowed == "t";
    const recommended = isAllowed
        ? currentDrug
        : (fallback.length() > 0 ? fallback : currentDrug);
    const safetyLabel = isAllowed ? "allowed" : "contraindicated";

    const districtField = isDefault
        ? "\"district\":null"
        : "\"district\":\"" + jsonEscape(canonical) + "\"";
    const contextSource = isDefault
        ? "default-group-a"
        : "user-supplied-district";

    return "{"
         + districtField + ","
         + "\"mftGroup\":\""                 + jsonEscape(mftGroup) + "\","
         + "\"mftContextSource\":\""         + contextSource + "\","
         + "\"mftCurrentDrug\":\""           + jsonEscape(currentDrug) + "\","
         + "\"mftDrugSafetyInTrimester\":\"" + safetyLabel + "\","
         + "\"mftRecommendedDrug\":\""       + jsonEscape(recommended) + "\""
         + "}";
}

// ── Severe-malaria pre-check (RBC 2024 — runs BEFORE the model) ─────────────
//
// Substring scan over the caller's text in both languages. The scan covers
// the canonical danger signs that REQUIRE referral under RBC 2024 protocol
// — convulsions, AVPU drop, vomiting everything, unable to drink/breastfeed,
// severe anaemia clues, pulse-oximetry red flags. Hit count is informational;
// a single hit is enough to short-circuit.

// dangerHitCount queries danger_signs (RBC-2024 protocol, seeded from the
// CHW handbook) for every keyword and counts substring matches in the
// patient note. The keyword list is structured truth that lives in the
// DB — never embedded in code, never inferred by an LLM. Always counts
// EN keywords; counts RW
// keywords only when lang=="rw" (matches the historical behaviour where
// CHW notes are predominantly EN with code-switched RW for severe
// signs). SQL is constant-only — no user input flows into the query —
// so no injection vector even though we don't have parameterised
// queries yet.
function dangerHitCount(textLower: string, lang: string): i64 {
    // Phase A: query the UNION of all known protocol keyword sets.
    // The severe-malaria criteria are functionally identical across
    // RBC-2024 (Rwanda) and WHO-2024 (Tanzania/Kenya teaching mode);
    // collapsing them here means we don't need to thread `country`
    // through the intent classifier or the doX functions. EN runs
    // always; RW only when the request lang is rw; SW only when sw.
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT keyword, lang FROM danger_signs "
      + "WHERE protocol_id IN ('RBC-2024', 'WHO-2024') "
      + "  AND lang IN ('en','rw','sw','fr')");
    const n: i64 = dbResultRowCount(r);
    let hits: i64 = 0;
    for (let i: i64 = 0; i < n; i = i + 1) {
        const kw:     string = dbResultGet(r, i, 0);
        const kwLang: string = dbResultGet(r, i, 1);
        const include = (kwLang == "en")
                     || (kwLang == "rw" && lang == "rw")
                     || (kwLang == "sw" && lang == "sw")
                     || (kwLang == "fr" && lang == "fr");
        if (include && textLower.indexOf(kw) >= 0) hits = hits + 1;
    }
    dbDisconnect(db);
    return hits;
}

// Severe-malaria referral text is split per-language so the response
// honours the caller's `lang=` choice consistently with every other
// endpoint. Earlier versions returned a bilingual concatenation, which
// looked accidental on a `lang=en` request even though the intent was
// "ship the message in both languages because severe-malaria is
// critical". The `[KOHEREZA]` / `[BIMENYETSO_BIBI]` tags appear in the
// response regardless of language because they're protocol markers,
// not human-readable prose.

function severeMalariaReferralEn(): string {
    return "[KOHEREZA] DANGER — SEVERE MALARIA SIGNS DETECTED. "
         + "REFER IMMEDIATELY to the nearest district hospital. "
         + "If rectal artesunate is available, administer per RBC 2024 "
         + "weight-band before transfer. Place patient on their side. "
         + "Do NOT give oral AL at home. Go now.";
}

function severeMalariaReferralRw(): string {
    return "[BIMENYETSO_BIBI] IBIMENYETSO BIKOMEYE BYA MALARIA BIRAGARAGARA. "
         + "KOHEREZA umurwayi VUBA ku bitaro by'akarere bya hafi. "
         + "Niba artesunate yo mu kibuno ihari, yitange ukurikije "
         + "imbonerahamwe ya RBC 2024 mbere yo kumwohereza ku bitaro. "
         + "Ryamisha umurwayi ku ruhande. NTUMUHE AL akiri mu rugo. IHUTE.";
}

function severeMalariaReferral(lang: string): string {
    if (lang == "rw") return severeMalariaReferralRw();
    return severeMalariaReferralEn();
}

// ── AL weight-band dose lookup ──────────────────────────────────────────────
// The al_weight_bands SQL lookup lives inline in assessHandler. The DB is
// the single source of truth for dose decisions.

// ── Pregnancy + treatment-failure detection ─────────────────────────────────
// Pregnancy detection runs in /v1/assess to catch the case where a CHW
// posts a pregnant patient's assessment to the wrong endpoint. RBC 2024
// hard rule: 1st-trimester pregnancy is quinine, NOT AL — silently
// returning an AL band would be a clinical safety bug. When we detect
// pregnancy markers we either reroute the response to the pregnancy
// prose template (if we also see weeks) or return a "please use
// /v1/pregnancy" prompt.

function isPregnant(textLower: string): bool {
    if (textLower.indexOf("pregnant") >= 0)            return true;
    if (textLower.indexOf("pregnancy") >= 0)           return true;
    if (textLower.indexOf("gestation") >= 0)           return true;
    if (textLower.indexOf("gravid") >= 0)              return true;
    if (textLower.indexOf("antenatal") >= 0)           return true;
    if (textLower.indexOf("anc visit") >= 0)           return true;
    if (textLower.indexOf("trimester") >= 0)           return true;
    if (textLower.indexOf("trimestre") >= 0)           return true;  // RW/FR-style spelling
    if (textLower.indexOf("expecting") >= 0)           return true;
    // Kinyarwanda
    if (textLower.indexOf("utwite") >= 0)              return true;  // pregnant
    if (textLower.indexOf("inda") >= 0)                return true;  // pregnancy/uterus
    if (textLower.indexOf("nyababyeyi") >= 0)          return true;  // ANC mother
    if (textLower.indexOf("ibyumweru by'inda") >= 0)   return true;
    // Swahili
    if (textLower.indexOf("mjamzito") >= 0)            return true;  // pregnant woman
    if (textLower.indexOf("ujauzito") >= 0)            return true;  // pregnancy
    if (textLower.indexOf("wajawazito") >= 0)          return true;  // pregnant women (pl)
    // French
    if (textLower.indexOf("enceinte") >= 0)            return true;  // pregnant
    if (textLower.indexOf("grossesse") >= 0)           return true;  // pregnancy
    if (textLower.indexOf("femme enceinte") >= 0)      return true;  // already covered by "enceinte" but explicit
    if (textLower.indexOf("consultation prénatale") >= 0) return true;
    if (textLower.indexOf("consultation prenatale") >= 0) return true;
    if (textLower.indexOf("cpn") >= 0)                 return true;  // consultation prénatale (FR ANC abbreviation)
    return false;
}

// Treatment-failure: post-AL fever continuing into day 3+ is the RBC
// 2024 marker for treatment failure. Refer to district hospital; never
// repeat AL. Detection requires both an AL/Coartem mention AND a
// failure marker — markers come from treatment_failure_markers (seeded
// from the CHW handbook). Same pattern as dangerHitCount: constant SQL,
// no user input in the query.
function treatmentFailureDetected(textLower: string): bool {
    if (!detectsAL(textLower)) return false;
    // Phase A: union across known protocols (same rationale as
    // dangerHitCount — marker sets are clinically identical).
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT keyword FROM treatment_failure_markers "
      + "WHERE protocol_id IN ('RBC-2024', 'WHO-2024')");
    const n: i64 = dbResultRowCount(r);
    let detected: bool = false;
    for (let i: i64 = 0; i < n; i = i + 1) {
        const kw: string = dbResultGet(r, i, 0);
        if (textLower.indexOf(kw) >= 0) { detected = true; break; }
    }
    dbDisconnect(db);
    return detected;
}

function treatmentFailureProseEn(): string {
    return "Day-3 treatment failure pattern detected (post-AL fever / "
         + "persistent positive RDT). RBC 2024: REFER to the district "
         + "hospital. Do NOT repeat AL — treatment failure requires a "
         + "second-line regimen (typically quinine or artesunate IV) "
         + "that only the district hospital can dispense. Document the "
         + "case in DHIS2 and report to the health-centre in-charge.";
}

function treatmentFailureProseRw(): string {
    return "Biragaragara ko imiti itakoze (umuriro ntugabanuka nyuma "
         + "y'iminsi 3 ya AL cyangwa RDT ikomeje kuba pozitifu). "
         + "RBC 2024: KOHEREZA umurwayi ku bitaro by'akarere. "
         + "NTUSUBIRE GUTANGA AL — ibitakoze bisaba undi muti (nka "
         + "quinine cyangwa artesunate ya intra-veinous) utangwa ku "
         + "bitaro gusa. Andika ibyabaye muri DHIS2 kandi umenyeshe "
         + "umuyobozi w'ikigo nderabuzima.";
}

// ── /v1/danger non-severe template ──────────────────────────────────────────
// When dangerHitCount returns 0 and treatmentFailureDetected is also false,
// the request describes a non-severe presentation (typical fever +
// patient still able to drink). Earlier proxies (llama3.1:8b,
// aya-expanse:8b) produced gibberish-Swahili on lang=rw; this path
// stays deterministic regardless of which LLM the proxy currently
// uses (now claude-haiku-4-5) so the Kinyarwanda response is
// reviewed-template quality, not model-best-effort. The text covers:
// no severe signs detected → monitor → reassess if symptoms persist
// → CHW reports back after 24h.

function dangerNoSevereProseEn(): string {
    return "Based on the information provided, there are no severe malaria "
         + "danger signs present in this child (fever, but able to drink). "
         + "Monitoring advice: Monitor for improvement or worsening of "
         + "symptoms. Continue to assess for any new symptoms and provide "
         + "supportive care as needed. If the fever persists or worsens, "
         + "reassess for potential malaria treatment. "
         + "Next step: Ask the CHW to report back on the child's condition "
         + "after 24 hours and provide further guidance based on their "
         + "response.";
}

function dangerNoSevereProseRw(): string {
    return "Dukurikije icyo batubwiye, malaria muri uyu mwana ntikaze cyane "
         + "(afite umuriro, ariko ashobora kunywa). "
         + "Ibyo twangenzura: twagenzura niba umuriro uzamuka cyangwa "
         + "umanuka tugakomeza kumuba hafi. Niba akomeje kugira umuriro "
         + "cyangwa se umuriro ukomeje kuzamuka, turebe niba byabaye "
         + "malaria, tumuhe imiti ya malaria. "
         + "Intambwe ikurikira: Dusabe Nshuti z'Ubuzima kuduha raporo ku ndwara y'uyu "
         + "mwana mu masaha 24, tubabwire ibyo bakora dukurikije igisubizo "
         + "cyabo.";
}

// ── /v1/prevention ITN distribution template (RW) ───────────────────────────
// Claude on lang=rw was producing inconsistent, sometimes mangled
// Kinyarwanda for the ITN-distribution preset. The text below is a
// CHW-reviewed canonical response. Detection is via substring scan
// for ITN distribution intent — when matched, the prevention handler
// returns this prose deterministically and skips the LLM. Other
// prevention queries (IRS, larviciding, free-form) still go to Claude.

function isItnDistributionIntent(textLower: string): bool {
    // Broad detection: any RW question mentioning ITNs gets the
    // CHW-reviewed prose. The handler's lang=="rw" guard means EN
    // ITN questions still go to Claude (Claude's English on this
    // topic is reliable). Earlier verb+noun-adjacency form missed
    // realistic CHW phrasing like "Nzakwirakwiza nte inzitiramibu
    // no kuyihugurira mu mudugudu wanjye?" — the verb root
    // "kwirakwiza" was separated from "inzitiramibu" by " nte ", so
    // "kwirakwiza inzitiramibu" as a single substring never matched.
    if (textLower.indexOf("inzitiramibu") >= 0) return true;
    if (textLower.indexOf("itn") >= 0)          return true;
    return false;
}

function preventionItnProseRw(): string {
    return "# Inama ku Mikoreshereze y'Inzitiramibu (ITN) - Inyoborere Ngufi\n\n"
         + "## **Abagomba Guhabwa Inzitiramibu**\n\n"
         + "* **Abagore batwite n'abana bari munsi y'imyaka 5**: Bahabwa umwihariko (ni bo bafite ibyago byinshi)\n"
         + "* **Urugo rwose**: Nibura inzitiramibu imwe ku bantu 2\n"
         + "* Reba urutonde rw'abanditswe; wirinde ko bamwe bahabwa kabiri\n\n"
         + "---\n\n"
         + "## **Ingingo z'Ingenzi zo Gutanga Inama - Koresha Ururimi Rworoheje**\n\n"
         + "**Kuryama Munsi y'Inzitiramibu:**\n\n"
         + "* Buri joro, umwaka wose (ntabwo ari mu gihe cy'imvura gusa)\n"
         + "* Inzitiramibu igomba gukomekwa neza munsi ya matela cyangwa aho baryama\n"
         + "* Nta mwenge ugomba kubamo → nihabamo umwenge, uhite usanwa ukoresheje ibikoresho byabugenewe cyangwa isimbuzwe\n"
         + "* Yimanike nibura amasaha 2-3 mbere yo kuryama (bituma umuti uyirimo ukwirakwira neza)\n\n"
         + "**Kwita no Kubungabunga Inzitiramibu:**\n\n"
         + "* Yoze buhoro ukoresheje amazi n'isabune inshuro 2-3 mu mwaka (ntukoreshe eau de Javel)\n"
         + "* Yumisha mu gicucu (izuba rigabanya imbaraga z'umuti uyirimo)\n"
         + "* Yirinde kuyibika hafi y'umwotsi, izuba cyangwa imiti yica udukoko\n\n"
         + "---\n\n"
         + "## **Ubutumwa bwo Kurwanya Malariya ku Rwego rw'Umuryango**\n\n"
         + "**Gutera Umuti mu Nzu (IRS):**\n\n"
         + "* Iyo abatera umuti bageze mu rugo, ntukogeshe inkuta mu byumweru 2 nyuma yo gutera umuti\n"
         + "* Funga amadirishya n'inzugi igihe batera umuti; kandi ukingire ibiryo n'ibikoresho byo mu gikoni\n"
         + "* IRS hamwe na ITN = uburinzi bukomeye kurushaho\n\n"
         + "**Kurandura Ahororokera Imibu:**\n\n"
         + "* Kuraho amazi ahagaze hafi y'amazu (indobo, imiferege, ibidendezi)\n"
         + "* Shyira uburyo bwo kuyobora amazi kure y'urugo\n"
         + "* Gutegura ibikorwa by'isuku rusange buri kwezi (cyane cyane mbere y'igihe cy'imvura)\n\n"
         + "**Uburyo bwo Gutanga Ubutumwa:**\n\n"
         + "* Ibiganiro ku bigo nderabuzima, cyane cyane mu mavuriro y'abagore batwite n'abana\n"
         + "* Abayobozi b'umudugudu → gutangaza ubutumwa mu baturage\n"
         + "* Kwerekana uko inzitiramibu imanikwa ahantu hahurira abantu benshi\n"
         + "* Gutanga ubutumwa kuri radiyo mu gihe cya malariya\n\n"
         + "---\n\n"
         + "## **Igihe cyo Kohereza Abantu Gufata Inzitiramibu**\n\n"
         + "* Inzitiramibu zangiritse cyane zidashobora gusanwa → bohereze ku kigo nderabuzima kugira ngo bahabwe izindi\n"
         + "* Mu bikorwa byo gutanga inzitiramibu ku bwinshi: korana n'umukozi ushinzwe malariya ku rwego rw'akarere\n\n"
         + "Komeza ubutumwa bworoheje, ubusubiremo kenshi, kandi bujyane n'imico n'imigenzo by'aho batuye.";
}

// ── /v1/prevention community-messaging template (RW) ────────────────────────
// School-aged-children ITN compliance focus. The preset payload mentions
// "inzitiramibu" (which would otherwise trigger the ITN-distribution
// template), so this detector must run BEFORE isItnDistributionIntent
// in the handler — community messaging is the more specific intent.

function isCommunityMessagingIntent(textLower: string): bool {
    if (textLower.indexOf("community messaging") >= 0) return true;
    if (textLower.indexOf("compliance") >= 0)          return true;
    if (textLower.indexOf("school-age") >= 0)          return true;
    if (textLower.indexOf("school age") >= 0)          return true;
    if (textLower.indexOf("shishikariza") >= 0)        return true;
    if (textLower.indexOf("ubutumwa bukwiriye") >= 0)  return true;
    if (textLower.indexOf("b'amashuli") >= 0)          return true;
    if (textLower.indexOf("b'amashuri") >= 0)          return true;
    return false;
}

function preventionCommunityProseRw(): string {
    return "# Ubutumwa bwo Gushishikariza Abana bari Mu Mashuri Gukoresha Inzitiramibu (ITN)\n\n"
         + "## Kuki Iri tsinda ry'Abana rigomba Kwitabwaho?\n\n"
         + "Abana bafite imyaka y'ishuri (5-17) akenshi ntibarara munsi y'inzitiramibu buri gihe, bamwe bagasangira uburiri cyangwa bagakoresha inzitiramibu nabi. Iyo bakoresha inzitiramibu neza kandi buri gihe, bifasha guhagarika ikwirakwira rya malariya no kurinda imiryango yose.\n\n"
         + "---\n\n"
         + "## Ubutumwa bw'Ibanze ku Nzitiramibu (ITN)\n\n"
         + "### **\"Inzitiramibu = Ingabo Zirinda Malariya\"**\n\n"
         + "* Sobanura ko inzitiramibu zikora neza *gusa* iyo zikoreshwa buri joro, atari igihe umuntu yumva arwaye gusa.\n"
         + "* Shimangira ko ari uburyo bwo kurinda umuryango:\n"
         + "  **\"Umwana uryamye munsi y'inzitiramibu = umuryango wose uba urinzwe neza.\"**\n"
         + "* Sobanura ko gusangira inzitiramibu bisanzwe kandi bifite umutekano (abana babiri bashobora kurara munsi y'inzitiramibu imwe niba itarangiritse).\n"
         + "* Subiza ikibazo cy'ubushyuhe n'ukutamererwa neza:\n"
         + "  **\"Inzitiramibu z'ubu zifite imyenge minini kurusha iza kera, zinjiramo umwuka neza. Ngwino ubyiyumvire.\"**\n\n"
         + "### Inama zifatika zo guteza imbere ikoreshwa:\n\n"
         + "* Manika inzitiramibu mbere y'uko bwira; shyiramo abana mu kuyimanika kugira ngo bumve ko ari iyabo.\n"
         + "* Inzitiramibu ntizigakore ku nkuta kandi zikomekwe neza munsi ya matela (ahari umwanya hose = imibu irinjira).\n"
         + "* Suzuma inzitiramibu buri kwezi urebe niba nta myenge irimo; ibikoresho byo kuyisana biboneka ku buntu ku kigo nderabuzima.\n\n"
         + "---\n\n"
         + "## Uburyo bwo Gukorera ku Rwego rw'Urugo n'Amashuri\n\n"
         + "* **Ubukangurambaga kw' ishuri:** Abarimu batangaze iminsi yo gusuzuma inzitiramibu; abana bavuge izangiritse; ikigo nderabuzima kigafasha kuzisana.\n"
         + "* **Ubutumwa butangwa n'urungano:** Abanyeshuri bakuru bashishikarize abandi gukoresha inzitiramibu; abana bato bakabigenderaho.\n"
         + "* **Gusura ingo n'abajyanama b'ubuzima:** Kwereka imiryango uko manika inzitiramibu neza; no kumva ibibazo bafite (igiciro, umwanya muto, kutamererwa neza).\n\n"
         + "---\n\n"
         + "## Gutera Umuti mu Nzu (IRS) no Gukoresha Imiti mu Mazi (kwica imibu mito -- Larviciding) *(Aho Bikenewe)*\n\n"
         + "* Sobanura ko gutera umuti mu nzu byibanda ku nkuta no ku myenge yo hejuru aho imibu iruhukira.\n"
         + "* **Ubutumwa:**\n"
         + "  **\"Inkuta zatewe umuti + inzitiramibu = uburinzi bwikubye kabiri.\"**\n"
         + "* Tegura abaturage mbere yo gutera umuti: menyesha amatariki, kwimura ibintu, no gusubira mu nzu nyuma y'uko humye (akenshi nyuma y'amasaha 2-4).\n"
         + "* Mu bikorwa byo gushyira imiti mu mazi ahagaze: tegura ibikorwa by'isuku rusange; ereka abana uko amazi ahagaze yororokeramo imibu.\n\n"
         + "---\n\n"
         + "## Gukangurira Abaturage Bose\n\n"
         + "* **Koresha abayobozi b'inzego z'ibanze na radiyo:** Tanga ubuhamya bw'\"ababyeyi barinda abana babo.\"\n"
         + "* **Ibikoresho by'amashusho:** Erekana umubu n'inzitiramibu kugira ngo abantu babone itandukaniro mu buryo bworoshye.\n"
         + "* **Ibihembo (niba ingengo y'imari ibihagije):** Ibyemezo ku mashuri ku miryango ikoresha inzitiramibu 100%; ibihembo bito ku batangaza inzitiramibu zangiritse.\n\n"
         + "---\n\n"
         + "## Ubutumwa Bw'Ingenzi\n\n"
         + "Gukoresha inzitiramibu bigomba kugaragara nk'ikintu gisanzwe, cyoroshye kandi cyemewe n'abaturage bose — atari nk'umutwaro cyangwa inshingano ziremereye.";
}

// ── /v1/prevention ITN-at-home (household protection) template (RW) ─────────
// Distinct from the ITN-distribution template (which is CHW-perspective,
// "how do I distribute nets"). This one is household-perspective —
// "how does my family use nets at home". Detector requires BOTH an
// ITN reference (inzitiramibu/itn) AND a household-scope marker
// (imiryango / mu rugo / household / families / at home), so it
// doesn't catch the ITN-distribution preset (which uses
// "kwirakwiza" + "mudugudu", not "imiryango"/"rugo").

function isItnAtHomeIntent(textLower: string): bool {
    const hasItn = (textLower.indexOf("inzitiramibu") >= 0)
                || (textLower.indexOf("itn") >= 0);
    if (!hasItn) return false;
    if (textLower.indexOf("imiryango") >= 0)   return true;
    if (textLower.indexOf("mu rugo") >= 0)     return true;
    if (textLower.indexOf("at home") >= 0)     return true;
    if (textLower.indexOf("households") >= 0)  return true;
    if (textLower.indexOf("household") >= 0)   return true;
    if (textLower.indexOf("families") >= 0)    return true;
    return false;
}

function preventionItnAtHomeProseRw(): string {
    return "# Kwirinda Malariya Hakoreshejwe Inzitiramibu (ITNs) n'Umutekano w'Abaturage\n\n"
         + "## Inzitiramibu Zatewemo Umuti (ITNs)\n\n"
         + "### **Uko Zikoreshwa Neza:**\n\n"
         + "* Manika inzitiramibu hejuru y'aho baryama buri mugoroba (mbere y'uko bwira igihe imibu itangira kuruma)\n"
         + "* Reba neza ko nta myenge cyangwa ibice byacitsemo; bisanwe ako kanya hakoreshejwe ibikoresho byabigenewe\n"
         + "* Shyira impande z'inzitiramibu munsi ya matela kugira ngo imibu itinjira mu myanya\n"
         + "* Abagize umuryango bose baryame munsi y'inzitiramibu — cyane cyane abana bari munsi y'imyaka 5 n'abagore batwite\n"
         + "* **Igihe inzitiramibu imara:** Isimbuzwe buri myaka 3; yozwe buhoro inshuro 2-3 mu mwaka hakoreshejwe isabune yoroheje n'amazi akonje (ntuyishyire mu mazi abira)\n\n"
         + "### **Intego yo kugeraho:**\n\n"
         + "Nibura inzitiramibu imwe kuri buri buriri cyangwa aho baryama mu rugo.\n\n"
         + "---\n\n"
         + "## Gutera Umuti mu Nzu (IRS)\n\n"
         + "* Amatsinda ya Leta atera umuti uramba ku nkuta z'inzu (urinda mu gihe cy'amezi 6-12)\n"
         + "* Imiryango igomba **kwemerera abatera umuti kwinjira mu rugo** kandi ntibogeshe inkuta mu byumweru 2 nyuma yo gutera umuti\n"
         + "* IRS hamwe na ITNs bitanga uburinzi bukomeye kurusha gukoresha kimwe gusa\n\n"
         + "---\n\n"
         + "## Kurwanya Imyororokere y'Imibu n'Isuku y'Ibidukikije\n\n"
         + "* **Kuvanaho amazi ahagaze** hafi y'amazu (ibidendezi, imiferege ifunze, inkono z'indabyo)\n"
         + "* Gupfuka neza ibikoresho bibikamo amazi\n"
         + "* Gukoresha imiti yica imibu mito mu mazi: Abashinzwe ubuzima bashobora gushyira imiti mu mazi manini; abaturage bagashyigikira ibyo bikorwa\n\n"
         + "---\n\n"
         + "## Ubutumwa bwo Guha Abaturage\n\n"
         + "### **Ingingo z'ingenzi zigomba kwibandwaho mu ngo:**\n\n"
         + "* **\"Koresha inzitiramibu yawe buri joro, n'iyo haba hashyushye.\"**\n"
         + "* **\"Inzitiramibu imwe kuri buri buriri — abana n'abagore batwite bahabwe umwihariko.\"**\n"
         + "* **\"Nta mwenge = nta malariya.\"**\n"
         + "* **\"Emera gutererwa umuti mu nzu; kandi ntukogeshe inkuta mu byumweru 2 nyuma yo gutera umuti.\"**\n"
         + "* **\"Pfuka indobo z'amazi kandi ukureho amazi ahagaze.\"**\n\n"
         + "### **Uruhare rw'Abayobozi cyangwa Abakangurambaga:**\n\n"
         + "Ba intangarugero mu gukoresha inzitiramibu mu rugo rwawe; kandi wereke imiryango uko zimanikwa n'uko zibungabungwa.\n\n"
         + "---\n\n"
         + "## Ubutumwa Bw'Ingenzi\n\n"
         + "ITNs + IRS + gucunga neza amazi yo mu rugo = uburinzi bukomeye bw'umuryango n'abaturage bose.";
}

// ── /v1/prevention IRS schedule template (RW) ───────────────────────────────
// Companion to the ITN-distribution template: Claude's RW on the IRS
// schedule preset was inconsistent, so this CHW-reviewed prose is the
// canonical response when the question is about IRS / spraying /
// gutera umuti. EN still goes to Claude (lang=="rw" guard in the
// handler).

function isIrsScheduleIntent(textLower: string): bool {
    if (textLower.indexOf("irs ikorwa") >= 0)      return true;
    if (textLower.indexOf("gahunda ya irs") >= 0)  return true;
    if (textLower.indexOf("indoor residual") >= 0) return true;
    if (textLower.indexOf("irs schedule") >= 0)    return true;
    if (textLower.indexOf("irs applied") >= 0)     return true;
    if (textLower.indexOf("gutera umuti") >= 0)    return true;
    if (textLower.indexOf(" irs ") >= 0)           return true;
    if (textLower.indexOf(" irs?") >= 0)           return true;
    if (textLower.indexOf(" irs.") >= 0)           return true;
    if (textLower.indexOf(" irs,") >= 0)           return true;
    return false;
}

function preventionIrsProseRw(): string {
    return "# Kwirinda Malariya mu Turere two mu Ntara y'Iburasirazuba Dukunze Kugira ubwandu bwinshi\n\n"
         + "## **Igihe cyo Gutera Umuti mu Nzu (IRS)**\n\n"
         + "* **Akenshi bikorwa hagati y' Ukwakira n' Ugushyingo** (mbere y'igihe cy'imvura) kugira ngo birusheho gutanga umusaruro mu gihe malariya iba yiyongereye cyane (Ugushyingo - Gicurasi)\n"
         + "* Baza ku **Biro by'Ubuzima by'Akarere kawe** kugira ngo umenye amatariki nyayo kuko ibikorwa bitandukana bitewe n'akarere n'imiterere y'imvura\n"
         + "* Umuti uterwa mu nzu ugira akamaro mu gihe kingana na **amezi 6-12**, bitewe n'ubwoko bw'imibu n'ubwoko bw'inkuta\n\n"
         + "---\n\n"
         + "## **Gukoresha Inzitiramibu Zirimo Umuti (ITN)**\n\n"
         + "* **Abagize urugo bose bagomba kurara munsi y'inzitiramibu buri joro**, cyane cyane mu gihe cy'imvura\n"
         + "* Ongera gushyiramo umuti cyangwa usimbuze inzitiramibu buri **myaka 2-3**, cyangwa nk'uko gahunda z'ubuzima zibiteganya\n"
         + "* **Abagore batwite n'abana bari munsi y'imyaka 5: ni bo bahabwa umwihariko**\n"
         + "* Suzuma inzitiramibu buri cyumweru urebe niba nta myenge irimo; isanwe cyangwa isimbuzwe niba yangiritse\n"
         + "* Manika inzitiramibu neza (ntihagire icyuho hagati yayo na matela cyangwa urukuta)\n\n"
         + "---\n\n"
         + "## **Gukoresha Imiti Yica Imibu ikiri mito (Larviciding)** *(Inshingano z'Umuryango n'Ibiro by'Ubuzima)*\n\n"
         + "* Byibanda ku hantu imibu yororokera (amazi ahagaze, ibishanga, imiferege)\n"
         + "* Bitanga umusaruro cyane mu **gihe cy'izuba** kuko amazi aba ari make kandi agaragara neza\n"
         + "* **Uruhare rwawe:** Kumenya ahantu imibu yororokera; kubimenyesha akarere; no gushyigikira ibikorwa by'isuku rusange\n"
         + "* Kuraho amazi ahagaze mu rugo no mu bikikije (amapine ashaje, indobo, inkono z'indabyo)\n\n"
         + "---\n\n"
         + "## **Ubutumwa bwo Guha Abaturage**\n\n"
         + "* **\"Rara munsi y'inzitiramibu buri joro\"** - ubu ni bwo butumwa bw'ingenzi\n"
         + "* IRS irinda imibu iruhukira mu nzu; inzitiramibu zikakurinda igihe uryamye\n"
         + "* **IRS hamwe na ITNs = uburinzi bukomeye cyane**\n"
         + "* Shishikariza abaturage kwemera abatera umuti kwinjira mu ngo\n"
         + "* Kuvura umuriro hakiri kare = kugabanya imibu ikwirakwiza malariya\n\n"
         + "---\n\n"
         + "**Saba Umuhuzabikorwa wa Malariya mu Karere kawe gahunda ya IRS ya 2024-25.**";
}

// ── /v1/report CHW form-completion template (RW) ────────────────────────────
// Triggered when the report describes the CHW filling out the
// referral form for a severe-malaria case. Specific markers:
// "ifishi" (form) + completion verbs.

function isFormCompletionReportIntent(textLower: string): bool {
    if (textLower.indexOf("yuzuza ifishi") >= 0)        return true;
    if (textLower.indexOf("ifishi yo kohereza") >= 0)   return true;
    if (textLower.indexOf("kuzuza ifishi") >= 0)        return true;
    if (textLower.indexOf("form completion") >= 0)      return true;
    if (textLower.indexOf("completing referral") >= 0)  return true;
    if (textLower.indexOf("referral form") >= 0)        return true;
    if (textLower.indexOf("completing form") >= 0)      return true;
    return false;
}

function reportFormCompletionProseRw(): string {
    return "# Ifishi yo Kohereza Umurwayi wa Malariya Ikabije - Raporo ya DHIS2 (Kayonza)\n\n"
         + "## Ibyiciro by'Amakuru Bigomba Kwandikwa\n\n"
         + "### **Amakuru y'Umurwayi n'Ubuzima**\n\n"
         + "* Izina, imyaka, ibiro, igitsina\n"
         + "* Itariki ibimenyetso byatangiriyeho n'itariki yapimweho (RDT cyangwa microscope)\n"
         + "* Igisubizo cyemejwe (P. falciparum / P. malariae / mixed)\n"
         + "* **Ibimenyetso bya malariya ikabije bihari:** guhinda umushyitsi, kubura ubwenge (AVPU), kuruka bikabije, kutabasha kunywa cyangwa konsa\n"
         + "* Ubuvuzi bwatanzwe mbere yo kohereza umurwayi: ingano ya rectal artesunate n'isaha yatangiweho, cyangwa AL (niba artesunate itabonetse)\n\n"
         + "### **Amakuru yo Kohereza Umurwayi**\n\n"
         + "* Ikigo nderabuzima yoherejwemo (izina n'ikode by'ibitaro by'akarere)\n"
         + "* Itariki n'isaha yoherejweho\n"
         + "* Uburyo bwo gutwara umurwayi bwateguwe\n"
         + "* Izina ry'inshuti y'Ubuzima (CHW) n'ikode ya poste de santé\n\n"
         + "### **Gukurikirana Umurwayi** *(niba amakuru abonetse)*\n\n"
         + "* Kwemeza ko umurwayi yageze ku kigo nderabuzima\n"
         + "* Ibyavuye mu buvuzi (niba byagaruwe nyuma)\n\n"
         + "---\n\n"
         + "## Uko Raporo Izamurwa Hashingiwe ku Rwego rw'Ubwandu\n\n"
         + "### **Akarere Kagaragaramo Ubwandu (Kayonza)**\n\n"
         + "* **Kwinjiza muri DHIS2:** Andika umurwayi mu cyiciro cya \"Confirmed malaria cases requiring referral\"\n"
         + "* **Kuzamura amakuru:** CHW → Ushinzwe Ubuzima ku Karere (ushinzwe malariya)\n"
         + "* **Igikorwa:** Akarere gakurikirana ibyavuye mu kuvura; kakabishyira muri raporo za buri kwezi zohererezwa gahunda y'igihugu ya malariya\n"
         + "* **Igihe:** Ako kanya cyangwa mu masaha 24 ku barwayi ba malariya ikabije\n\n"
         + "### **Uturere Tudafite Cyangwa Dufite Malariya Nke Cyane**\n\n"
         + "* **Kwinjiza muri DHIS2:** Guhita byandikwa nk'\"Alert case\" (gukurikirana ibyorezo)\n"
         + "* **Kuzamura amakuru:** CHW → Ushinzwe Ubuzima ku Karere → **Umuhuzabikorwa wa malariya ku Ntara** → **Gahunda y'Igihugu yo Kurwanya Malariya (NMCP)**\n"
         + "* **Igikorwa:** Gukora iperereza ryihuse mu masaha 48; kumenya inkomoko y'ubwandu (bwaturutse hanze cyangwa bwo mu gace); no gushakisha abandi barwayi mu ntera ya kilometero 1-2\n"
         + "* **Igihe:** Kumenyekanisha uwo munsi cyangwa bukeye bwaho\n\n"
         + "---\n\n"
         + "## Urutonde Rugufi rw'ibyo Inshuti y'Ubuzima (CHW) agomba gukora\n\n"
         + "✓ Rectal artesunate yatanzwe mbere yo kohereza umurwayi kandi byanditswe neza\n"
         + "✓ Ifishi yo kohereza umurwayi yujujwe yose (nta mwanya usigaye ubusa)\n"
         + "✓ Umurwaza cyangwa umubyeyi yahawe kopi n'amabwiriza yo kohereza umurwayi\n"
         + "✓ Ifishi yashyikirijwe umugenzuzi wa poste de santé ako kanya\n"
         + "✓ Gukurikirana ko umurwayi yageze ku kigo nderabuzima mu masaha 24 niba bishoboka\n\n"
         + "**Icyitonderwa:** Ntutinde kohereza umurwayi kubera kuzuza impapuro. Umutekano w'umurwayi ni wo uza mbere.";
}

// ── /v1/report active-transmission template (RW) ───────────────────────────
// Companion to the zero-cases template. Triggered when the report
// describes ongoing transmission with a confirmed-case count and/or
// severe-malaria referrals. Detector should run BEFORE the zero-cases
// detector so the more specific case lands first.

function isActiveTransmissionReportIntent(textLower: string): bool {
    if (textLower.indexOf("active transmission") >= 0)   return true;
    if (textLower.indexOf("confirmed cases") >= 0)       return true;
    if (textLower.indexOf("severe referrals") >= 0)      return true;
    if (textLower.indexOf("ubwandu burakomeza") >= 0)    return true;
    if (textLower.indexOf("ubwandu bukomeza") >= 0)      return true;
    if (textLower.indexOf("abarwaye malariya") >= 0)     return true;
    if (textLower.indexOf("zemejwe muri iki cyumweru") >= 0) return true;
    if (textLower.indexOf("malariya ikabije") >= 0 && textLower.indexOf("kuvurwa") >= 0) return true;
    return false;
}

function reportActiveTransmissionProseRw(): string {
    return "# Gutanga Raporo ya Malariya muri DHIS2 - Kayonza (Ubwandu Burakomeza Gukwirakwira)\n\n"
         + "## Ibyiciro by'Amakuru Byandikwa (Ku Rwego rw'Inshuti y'Ubuzima - CHW)\n\n"
         + "### **Kumenya Umurwayi**\n\n"
         + "* Nimero cyangwa izina ry'umurwayi (bitamenyekanisha umuntu muri DHIS2)\n"
         + "* Imyaka, igitsina, ibiro\n"
         + "* Aho atuye (umudugudu, umurenge)\n"
         + "* Itariki ibimenyetso byatangiriye\n"
         + "* Itariki yapimweho (RDT cyangwa microscope)\n"
         + "* Igisubizo cy'ikizamini (yanduye / ntiyanduye)\n\n"
         + "### **Icyiciro cy'Indwara**\n\n"
         + "* Malariya yoroheje cyangwa ikabije\n"
         + "* Uko gutwita guhagaze (igihembwe niba bikenewe)\n"
         + "* Izindi ndwara afite (SIDA, imirire mibi, n'izindi)\n\n"
         + "### **Ubuvuzi Bwatanzwe**\n\n"
         + "* Umuti wakoreshejwe (AL / quinine / artesunate)\n"
         + "* Doze y'umuti n'itariki watangiweho\n"
         + "* Umurwayi yagenzuwe mu minota 30 nyuma yo gufata umuti\n\n"
         + "### **Ibyavuye mu Kuvura ku Munsi wa 3**\n\n"
         + "* Korohererwa / kuvurwa byanze / gukurikiranwa byananiranye\n"
         + "* Aboherejwe kubera malariya ikabije: izina ry'ikigo boherejwemo, igihe bagezeyo, artesunate yatanzwe mbere yo koherezwa (Yego/Oya)\n\n"
         + "---\n\n"
         + "## Uko Raporo Izamurwa mu Nzego\n\n"
         + "### **Akarere Kagaragaramo Ubwandu (Kayonza: abarwayi 47 mu cyumweru)**\n\n"
         + "1. **Inshuti y'Ubuzima (CHW) → Umuyobozi w'Ibiro by'Ubuzima** (buri munsi cyangwa kabiri mu cyumweru)\n\n"
         + "   * Gutegura urutonde rw'abarwayi rwa buri cyumweru\n"
         + "   * Gutanga amakuru yihutirwa: impfu, kuvura byanze, aboherejwe kubera malariya ikabije\n\n"
         + "2. **Ibiro by'Ubuzima → Umuyobozi Ushinzwe HMIS mu Karere** (buri cyumweru)\n\n"
         + "   * Kwinjiza amakuru muri DHIS2\n"
         + "   * Gushyiramo incamake y'akarere: abarwayi bemejwe, abafite malariya ikabije, n'abohererejwe mu bitaro\n\n"
         + "3. **Akarere → Gahunda ya Malariya muri RBC** (buri kwezi n'igihe bibaye ngombwa)\n\n"
         + "   * Gutanga impuruza niba:\n\n"
         + "     * Hari ahantu habonetse abarwayi benshi hamwe\n"
         + "     * Umubare munini wa malariya ikabije\n"
         + "     * Kuvura byanze birenze 5%\n"
         + "   * Gusaba gusuzuma ububiko bw'imiti (AL, RDTs, artesunate)\n\n"
         + "### **Impuruza Yihariye:**\n\n"
         + "Urupfu urwo ari rwo rwose, cyangwa abarwayi barenze 2 bafite malariya ikabije mu cyumweru kimwe → guhita bahamagara umuhuzabikorwa w'akarere.\n\n"
         + "---\n\n"
         + "## **Akarere Kadafite Abarwayi (Kugenzura)**\n\n"
         + "* Inshuti y'ubuzima (CHW) atanga raporo buri cyumweru (\"0 cases\" niba nta murwayi wabonetse)\n"
         + "* **Nta kuvura hakoreshejwe gukeka gusa hatabanje kwemezwa na RDT**\n"
         + "* Umurwayi wese wemejwe → guhita bitangazwa ku karere na RBC (ikimenyetso cy'uko malariya yongeye kugaruka)\n"
         + "* Gukomeza ubukangurambaga no gukomeza inzira zo gutanga amakuru ku barwayi\n\n"
         + "---\n\n"
         + "## Iby'Ingenzi ku Nshuti z'Ubuzima (CHW)\n\n"
         + "✓ Andika amakuru yose yuzuye *mbere* yo kuyashyira muri DHIS2\n"
         + "✓ Aboherejwe 2 kubera malariya ikabije muri iki cyumweru: emeza ko bahawe artesunate kandi ko ikigo cyabakiriye?\n"
         + "✓ Hari abananiwe gukira ku munsi wa 3? → Bohereze ku karere kugira ngo hakorwe iperereza";
}

// ── /v1/report zero-cases template (RW) ─────────────────────────────────────
// Companion to the prevention deterministic templates: Claude on
// lang=rw was producing inconsistent Kinyarwanda for the zero-cases
// reporting scenario. This CHW-reviewed prose is the canonical
// response when the question describes a zero-malaria-cases week
// (any RW report query mentioning "nta malariya" / "kagize Imana"
// or EN markers like "zero cases" / "zero malaria"). EN keeps
// going to Claude.

function isZeroCasesReportIntent(textLower: string): bool {
    if (textLower.indexOf("zero malaria") >= 0)    return true;
    if (textLower.indexOf("zero cases") >= 0)      return true;
    if (textLower.indexOf("no malaria cases") >= 0) return true;
    if (textLower.indexOf("nta malariya") >= 0)    return true;
    if (textLower.indexOf("kagize imana") >= 0)    return true;
    return false;
}

function reportZeroCasesProseRw(): string {
    return "# Gutanga Raporo y'ibarura rya Malariya muri DHIS2 - Ntayihari mu karere ka Burera\n\n"
         + "## Ibyiciro By'Ingenzi Bigomba Kwandikwa\n\n"
         + "### **Kwinjiza Amakuru ya Buri Cyumweru muri DHIS2:**\n\n"
         + "* **Umubare w'abanduye malariya byemejwe** = 0\n"
         + "* **Umubare wa RDT zakozwe** (mu cyumweru cyose)\n"
         + "* **Igipimo cya RDT zabonetsemo malariya** (%)\n"
         + "* **Impfu zatewe na malariya** = 0\n"
         + "* **Aboherejwe kuvurwa malariya ikabije** (niba bahari)\n"
         + "* **Ingano ya AL yatanzwe** (n'ibisigaye mu bubiko)\n"
         + "* **Kubura imiti cyangwa ibikoresho** (Yego/Oya + igihe byamaze)\n"
         + "* **Gukurikirana abanduye bo mu byumweru bishize byarangiye** (niba hari ibisigaye)\n\n"
         + "### **Ibimenyetso by'Ubuziranenge bw'Amakuru:**\n\n"
         + "* Itariki ya nyuma habonetse umurwayi wa malariya\n"
         + "* Umubare w'abapimwe cyangwa abaturage serivisi zagezeho\n"
         + "* Imiterere y'ububiko bwa RDT (bihagije/bike/byashize)\n\n"
         + "---\n\n"
         + "## Uko Amakuru Azamurwa mu Nzego\n\n"
         + "### **Akarere Kataragaragayemo Malariya (Burera)**\n\n"
         + "1. **Umujyanama w'Ubuzima (CHW) → Umugenzuzi w'Ikigo Nderabuzima**\n\n"
         + "   * Kugenzura neza ko amakuru ari ukuri (nta barwayi basigaye cyangwa RDT zashize)\n"
         + "   * Kwemeza ko umubare w'abapimwe ujyanye n'ingano y'abaturage\n\n"
         + "2. **Ikigo Nderabuzima → Ushinzwe Malariya ku Karere**\n\n"
         + "   * Kuzamura amakuru nk'**ikimenyetso cyiza cyo guhashya malariya**\n"
         + "   * Gusaba gushimira ikipe no gusuzuma niba uburyo bwo gukurikirana bukora neza\n\n"
         + "3. **Akarere → RBC n'Urwego rw'Igihugu rw'Ubuzima**\n\n"
         + "   * RBC ikurikirana ibyumweru bidafite malariya kugira ngo harebwe **impinduka mu ishusho y'icyorezo**\n"
         + "   * Bishobora gutuma **igipimo cyo gukurikirana kigabanywa** niba bikomeje ibyumweru 4 cyangwa birenga\n\n"
         + "---\n\n"
         + "### **Akarere Kakigaragaramo Ubwandu (Kugereranya)**\n\n"
         + "* Buri cyumweru hazamurwa:\n\n"
         + "  * Umubare w'abarwaye\n"
         + "  * Impfu\n"
         + "  * Abafite malariya ikabije\n\n"
         + "* Hafatwa ingamba zihuse niba umubare w'abarwayi urenze igipimo cyateganyijwe\n\n"
         + "---\n\n"
         + "## Ubutumwa Bw'Ingenzi ku Nshuti z'Ubuzima (CHW)\n\n"
         + "**Niba ntabarwaye ntibivuze ko nta kazi.**\n"
         + "Mukomeze gupima RDT nk'uko bisanzwe kandi mutange raporo z'ibizamini byose — ibi bigaragaza ko gahunda yo gukurikirana ikora neza. Mubanze murebe neza ko ibikoresho bihagije mbere yo gutangaza ko nta malariya ihari koko.";
}

// ── Drug name aliases ───────────────────────────────────────────────────────
// CHWs and clinicians refer to artemether-lumefantrine by many names:
//   AL, Coartem (Novartis brand), Lonart (local generic), Riamet (EU brand),
//   artemether-lumefantrine (generic), artemether/lumefantrine.
// detectsAL(text) returns true if any alias is mentioned, so handler logic
// can correctly recognize the patient is already on AL (relevant to
// treatment-failure detection and severe-malaria gate prose).

// containsWord(text, word) — true iff `word` appears in `text` with
// non-word characters (or start/end of string) on both sides. Used
// for word_boundary matches in drug_aliases. Pads the text with
// space sentinels so start/end behave like middle, then enumerates
// the realistic non-word chars a CHW note might write after the
// term (space, punctuation, parens, slash, hyphen, newline).
//
// The alternative — a real char-class scan — would need either
// charCodeAt (not in Abe v4.1) or per-position substring(i, i+1)
// comparisons. The enumerated approach is verbose but correct for
// every real case we hit.
function containsWord(text: string, word: string): bool {
    const padded = " " + text + " ";
    if (padded.indexOf(" " + word + " ")  >= 0) return true;
    if (padded.indexOf(" " + word + ",")  >= 0) return true;
    if (padded.indexOf(" " + word + ".")  >= 0) return true;
    if (padded.indexOf(" " + word + ":")  >= 0) return true;
    if (padded.indexOf(" " + word + ";")  >= 0) return true;
    if (padded.indexOf(" " + word + "?")  >= 0) return true;
    if (padded.indexOf(" " + word + "!")  >= 0) return true;
    if (padded.indexOf(" " + word + "/")  >= 0) return true;
    if (padded.indexOf(" " + word + "-")  >= 0) return true;
    if (padded.indexOf(" " + word + "(")  >= 0) return true;
    if (padded.indexOf(" " + word + ")")  >= 0) return true;
    if (padded.indexOf(" " + word + "\n") >= 0) return true;
    if (padded.indexOf(" " + word + "\t") >= 0) return true;
    return false;
}

// detectsAL queries drug_aliases for every alias of canonical_drug='AL'
// (Coartem, Lonart, Riamet, artemether-lumefantrine variants, plus
// "AL course"/"AL treatment"/"AL regimen" substring forms and the
// stand-alone "AL" word_boundary form). Match semantics come from the
// match_form column: substring uses plain indexOf, word_boundary uses
// containsWord. This corrects the pre-existing limitation where a body
// starting "AL day 3..." failed to match because the old code required
// " al " with a leading space.
function detectsAL(textLower: string): bool {
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT alias, match_form FROM drug_aliases "
      + "WHERE canonical_drug = 'AL'");
    const n: i64 = dbResultRowCount(r);
    let found: bool = false;
    for (let i: i64 = 0; i < n; i = i + 1) {
        const aliasRaw:  string = dbResultGet(r, i, 0);
        const matchForm: string = dbResultGet(r, i, 1);
        const alias = aliasRaw.toLowerCase().trim();
        if (matchForm == "word_boundary") {
            if (containsWord(textLower, alias)) { found = true; break; }
        } else if (matchForm == "exact") {
            if (textLower.trim() == alias) { found = true; break; }
        } else {
            // substring (default + explicit)
            if (textLower.indexOf(alias) >= 0) { found = true; break; }
        }
    }
    dbDisconnect(db);
    return found;
}

// ── Deterministic prose templates ───────────────────────────────────────────
// Hand-written EN + RW prose that wraps the verifiedDose / verifiedTrimester
// structured fields. We bypass the LLM entirely when the deterministic
// anchor is available — clinical structure (dose, trimester, treatment
// failure, severe gate) is never derived from a model. The proxy
// landscape we walked through:
//   1. aya-expanse:8b — produced morphology-shaped Kinyarwanda
//      non-words ("umupfumi wa gacaciro" instead of "umwana") and
//      occasional Romanian drift on EN prompts. Replaced.
//   2. llama3.1:8b — clean clinical English, no real Kinyarwanda
//      (drifted into Swahili on RW prompts). Replaced.
//   3. A hosted Anthropic Messages backend (current) — knows
//      Kinyarwanda properly and handles clinical reasoning well; the
//      trade-off is that this backend is online-only.
// These templates remain the source of truth for assess + pregnancy
// prose regardless of which LLM backend is plugged in, because clinical
// structure should not depend on a model's mood. The LLM is only
// consulted on /v1/prevention and /v1/report — prose-around-deterministic
// paths where drift is less safety-critical.

// Returns the right "of-class" connector for a band label that follows
// "mu kiciro" — `cy'` before vowel-initial words, `cya ` before
// consonant-initial words. Kinyarwanda noun-class rule for the
// connective `-a` of class 7 (icyiciro / kiciro).
function cysepRw(band: string): string {
    if (band.length() == 0) return "cya ";
    const c = band.substring(0, 1);
    if (c == "a" || c == "e" || c == "i" || c == "o" || c == "u") return "cy'";
    if (c == "A" || c == "E" || c == "I" || c == "O" || c == "U") return "cy'";
    return "cya ";
}

// Assess prose. Wraps the per-drug schedule string (which comes from
// antimalarial_weight_bands.schedule_en/rw and already contains the
// full dosing instruction — "1 tablet 6 doses over 60 hours..." for
// AL, "Once daily for 3 days..." for ASPY/DHAP) with the patient
// context + danger-sign reminder. drug is the canonical name
// (AL/ASPY/DHAP) so the prose explicitly says which drug.
function assessProseEn(kg: f64, drug: string, band: string, schedule: string): string {
    return "For a patient weighing " + (kg as i64) + " kg, the RBC 2024 "
         + "weight-band table for " + drug + " assigns the " + band + " band: "
         + schedule + " [DOSE_ALERT] Verify the weight and band before each "
         + "dose. If any danger signs appear (convulsions, unable to drink or "
         + "breastfeed, persistent vomiting, severe weakness), refer immediately "
         + "to the nearest health centre regardless of the dose given.";
}

function assessProseRw(kg: f64, drug: string, band: string, schedule: string): string {
    return "Umurwayi w'ibiro " + (kg as i64) + " kg, dukurikije "
         + "imbonerahamwe ya RBC 2024 ya " + drug + ", ari mu kiciro "
         + cysepRw(band) + band + ": " + schedule + " [DOSE_ALERT] Suzuma "
         + "uburemere n'icyiciro mbere ya buri doze. Niba ibimenyetso bibi "
         + "byagaragaye (guhungabana, kunywa cyangwa konka bigoye, kuruka "
         + "bidahwema, intege nke bikabije), ohereza umurwayi byihuse ku "
         + "bitaro, ntiwite kuri doze watanze.";
}

function assessProseNoWeightEn(): string {
    return "To recommend a dose, please include the patient's weight in "
         + "kilograms in the request (for example: \"child 22kg RDT "
         + "positive no danger signs\"). If danger signs are present "
         + "(convulsions, unable to drink/breastfeed, persistent vomiting), "
         + "refer immediately regardless of weight.";
}

function assessProseNoWeightRw(): string {
    return "Kugira ngo duhe inama y'imiti, andika uburemere bw'umurwayi "
         + "muri kg muri ubu butumwa (urugero: \"umwana kg 22 RDT yiza nta "
         + "bimenyetso bibi\"). Niba ibimenyetso bibi biriho (kuhungabana, "
         + "kunywa cyangwa konka bigora, kuruka bidahwema), ohereza vuba "
         + "uretse uburemere.";
}

// There is deliberately no "refer to health centre" path for non-AL
// provinces: per Rwanda's MFT Q&A page 9, CHWs are explicitly authorised
// to dose whichever drug is assigned to their group's rotation (AL, ASPY,
// or DHAP). The code path goes straight from district → group → current
// drug → drug-specific weight bands.

// RBC 2024 §6.1 (5th edition): AL and DHAP indicated in all trimesters
// including 1st; ASPY contraindicated in 1st only. Earlier quinine-first
// wording reflected pre-2024 guidance. RW prose native-speaker reviewed.
function pregnancyProseEn(weeks: i64, trim: i64): string {
    if (trim == 1) {
        return "At " + weeks + " weeks gestation the patient is in the "
             + "FIRST trimester. RBC 2024 (5th edition, §6.1): AL or DHAP "
             + "indicated for uncomplicated malaria in 1st trimester. "
             + "ASPY is contraindicated. Quinine retained only as "
             + "fallback if ACT is unavailable or contraindicated. "
             + "Confirm gestational age against the antenatal record "
             + "before starting therapy. Refer if any danger signs appear.";
    }
    const ordinal = trim == 2 ? "SECOND" : "THIRD";
    return "At " + weeks + " weeks gestation the patient is in the "
         + ordinal + " trimester. RBC 2024 (§6.1): AL, DHAP, or ASPY all "
         + "acceptable; use per the patient's MFT group rotation, "
         + "dosed by weight band. Refer if any danger signs appear.";
}

function pregnancyProseRw(weeks: i64, trim: i64): string {
    if (trim == 1) {
        return "Mu byumweru " + weeks + " by'inda, umurwayi ari mu mezi "
             + "atatu ya MBERE y'inda (trimestre ya mbere). Hakurikijwe "
             + "amabwiriza ya RBC 2024 §6.1: AL cyangwa DHAP byemewe ku "
             + "malariya yoroshye mu trimestre ya mbere. ASPY ntiyemewe. "
             + "Quinine ikoreshwa gusa iyo ACT idahari cyangwa itemewe. "
             + "Suzuma ibyumweru by'inda mu mateka y'isuzuma ry'umubyeyi "
             + "mbere yo kumuha imiti. Ohereza umurwayi byihuse ku bitaro "
             + "niba ibimenyetso bibi byagaragaye.";
    }
    const ordinalRw = trim == 2 ? "kabiri" : "gatatu";
    return "Mu byumweru " + weeks + " by'inda, umurwayi ari mu mezi "
         + "atatu ya " + ordinalRw + " y'inda (trimestre ya " + ordinalRw
         + "). Hakurikijwe amabwiriza ya RBC 2024 §6.1: AL, DHAP, cyangwa "
         + "ASPY byose byemewe; koresha hakurikijwe ihinduka ry'imiti "
         + "mw'itsinda ry'umurwayi (MFT), muhe doze hakurikijwe ibiro. "
         + "Ohereza umurwayi byihuse ku bitaro niba ibimenyetso bibi "
         + "byagaragaye.";
}

function pregnancyProseNoWeeksEn(): string {
    return "Please include the gestational age in weeks (for example: "
         + "\"pregnant 8 weeks RDT positive\"). Per RBC 2024 §6.1, AL "
         + "and DHAP are indicated in all trimesters; ASPY is "
         + "contraindicated in 1st trimester. Without the gestational "
         + "age the trimester-specific rules cannot be applied safely.";
}

function pregnancyProseNoWeeksRw(): string {
    return "Andika ibyumweru by'inda (urugero: \"niba utwite ibyumweru 8 "
         + "kandi RDT yawe iri pozitive\"). Hakurikijwe amabwiriza ya "
         + "RBC 2024 §6.1: AL na DHAP byemewe muri trimestre zose; ASPY "
         + "NTIYEMEWE mu trimestre ya mbere. Nta byumweru by'inda, "
         + "ntidushobora kumuha umuti ukwiriye.";
}

// Parse a weight token out of a free-form CHW input. Returns 0.0 when
// no weight is found; caller treats that as "skip the deterministic
// dose append, the LLM narrative is all we have".
//
// Approach: substring lookup over realistic CHW weight values.
// Iterates from largest (4-tab band) to smallest (1-tab band) so a
// "25kg" in the text doesn't false-match the "5kg" substring inside
// it. Codegen has no charCodeAt / parseI64 in v4.1, so a digit-scan
// parser isn't expressible — this lookup table is.
//
// Each entry tries "Nkg" then "N kg" forms; both common in CHW notes
// and in our synthetic dataset templates.
function tryWeight(text: string, kg: i64): bool {
    const tag1 = "" + kg + "kg";
    if (text.indexOf(tag1) >= 0) return true;
    const tag2 = "" + kg + " kg";
    if (text.indexOf(tag2) >= 0) return true;
    // Kinyarwanda often writes weight as "kg N" (unit before number).
    const tag3 = "kg " + kg;
    if (text.indexOf(tag3) >= 0) return true;
    const tag4 = "kg" + kg;
    if (text.indexOf(tag4) >= 0) return true;
    // Open band "Nkg+" or "Nkg+" — the "+" form means "above N" so we
    // accept N as the lower-bound weight.
    const tag5 = "" + kg + "kg+";
    if (text.indexOf(tag5) >= 0) return true;
    const tag6 = "" + kg + "+kg";
    if (text.indexOf(tag6) >= 0) return true;
    // Kinyarwanda natural phrasing: "umwana w'ibiro 12", "afite ibiro 12",
    // "ibiro 12 kg". Pad with a trailing space sentinel so an "ibiro 12"
    // at the very end of the message is followed by a boundary char.
    // Largest-first iteration in parseWeightKg means "ibiro 150" matches
    // at kg=150 before kg=15, so substring-into-larger isn't a concern.
    const padded = text + " ";
    const baseRw = "ibiro " + kg;
    if (padded.indexOf(baseRw + " ")  >= 0) return true;
    if (padded.indexOf(baseRw + "kg") >= 0) return true;
    if (padded.indexOf(baseRw + ",")  >= 0) return true;
    if (padded.indexOf(baseRw + ".")  >= 0) return true;
    if (padded.indexOf(baseRw + ";")  >= 0) return true;
    if (padded.indexOf(baseRw + ":")  >= 0) return true;
    if (padded.indexOf(baseRw + "?")  >= 0) return true;
    if (padded.indexOf(baseRw + "!")  >= 0) return true;
    if (padded.indexOf(baseRw + ")")  >= 0) return true;
    // Swahili natural phrasing: "mtoto wa kilo 12", "kilo 12 mtoto",
    // "uzito wa kilo 12". Same boundary-char-padded approach as the
    // Kinyarwanda block above. "kilo" is the Swahili loanword most
    // CHWs use; we also accept "kg" forms which are already covered
    // by tag1-tag4 above.
    const baseSw = "kilo " + kg;
    if (padded.indexOf(baseSw + " ")  >= 0) return true;
    if (padded.indexOf(baseSw + "kg") >= 0) return true;
    if (padded.indexOf(baseSw + ",")  >= 0) return true;
    if (padded.indexOf(baseSw + ".")  >= 0) return true;
    if (padded.indexOf(baseSw + ";")  >= 0) return true;
    if (padded.indexOf(baseSw + ":")  >= 0) return true;
    if (padded.indexOf(baseSw + "?")  >= 0) return true;
    if (padded.indexOf(baseSw + "!")  >= 0) return true;
    if (padded.indexOf(baseSw + ")")  >= 0) return true;
    return false;
}

// Range form "Nkg-Mkg" or "N-Mkg" — we use the LOWER bound (more
// conservative dose) per RBC weight-band semantics where a child near
// a band boundary should get the smaller dose. Returns the lower kg
// value if found, otherwise 0.
function tryRange(text: string): f64 {
    // Common ranges seen in CHW notes: "5-14kg", "15-24kg", "25-34kg",
    // "35+kg". Narrow lookup table avoids false positives.
    if (text.indexOf("5-14kg") >= 0)  return 8.0;
    if (text.indexOf("5-14 kg") >= 0) return 8.0;
    if (text.indexOf("15-24kg") >= 0)  return 18.0;
    if (text.indexOf("15-24 kg") >= 0) return 18.0;
    if (text.indexOf("25-34kg") >= 0)  return 28.0;
    if (text.indexOf("25-34 kg") >= 0) return 28.0;
    return 0.0;
}

// Decimal weight form "N.5kg" — the tenths position. Covers the
// realistic range for paediatric and adult patients. Iterating
// largest-first so "22.5kg" matches before any whole-number substring
// (avoids the "5kg substring of 22.5kg" false-positive).
function tryDecimalHalf(text: string): f64 {
    if (text.indexOf("80.5kg") >= 0 || text.indexOf("80.5 kg") >= 0) return 80.5;
    if (text.indexOf("70.5kg") >= 0 || text.indexOf("70.5 kg") >= 0) return 70.5;
    if (text.indexOf("60.5kg") >= 0 || text.indexOf("60.5 kg") >= 0) return 60.5;
    if (text.indexOf("55.5kg") >= 0 || text.indexOf("55.5 kg") >= 0) return 55.5;
    if (text.indexOf("50.5kg") >= 0 || text.indexOf("50.5 kg") >= 0) return 50.5;
    if (text.indexOf("45.5kg") >= 0 || text.indexOf("45.5 kg") >= 0) return 45.5;
    if (text.indexOf("40.5kg") >= 0 || text.indexOf("40.5 kg") >= 0) return 40.5;
    if (text.indexOf("38.5kg") >= 0 || text.indexOf("38.5 kg") >= 0) return 38.5;
    if (text.indexOf("36.5kg") >= 0 || text.indexOf("36.5 kg") >= 0) return 36.5;
    if (text.indexOf("35.5kg") >= 0 || text.indexOf("35.5 kg") >= 0) return 35.5;
    if (text.indexOf("34.5kg") >= 0 || text.indexOf("34.5 kg") >= 0) return 34.5;
    if (text.indexOf("33.5kg") >= 0 || text.indexOf("33.5 kg") >= 0) return 33.5;
    if (text.indexOf("32.5kg") >= 0 || text.indexOf("32.5 kg") >= 0) return 32.5;
    if (text.indexOf("31.5kg") >= 0 || text.indexOf("31.5 kg") >= 0) return 31.5;
    if (text.indexOf("30.5kg") >= 0 || text.indexOf("30.5 kg") >= 0) return 30.5;
    if (text.indexOf("28.5kg") >= 0 || text.indexOf("28.5 kg") >= 0) return 28.5;
    if (text.indexOf("26.5kg") >= 0 || text.indexOf("26.5 kg") >= 0) return 26.5;
    if (text.indexOf("25.5kg") >= 0 || text.indexOf("25.5 kg") >= 0) return 25.5;
    if (text.indexOf("24.5kg") >= 0 || text.indexOf("24.5 kg") >= 0) return 24.5;
    if (text.indexOf("23.5kg") >= 0 || text.indexOf("23.5 kg") >= 0) return 23.5;
    if (text.indexOf("22.5kg") >= 0 || text.indexOf("22.5 kg") >= 0) return 22.5;
    if (text.indexOf("21.5kg") >= 0 || text.indexOf("21.5 kg") >= 0) return 21.5;
    if (text.indexOf("20.5kg") >= 0 || text.indexOf("20.5 kg") >= 0) return 20.5;
    if (text.indexOf("18.5kg") >= 0 || text.indexOf("18.5 kg") >= 0) return 18.5;
    if (text.indexOf("16.5kg") >= 0 || text.indexOf("16.5 kg") >= 0) return 16.5;
    if (text.indexOf("15.5kg") >= 0 || text.indexOf("15.5 kg") >= 0) return 15.5;
    if (text.indexOf("14.5kg") >= 0 || text.indexOf("14.5 kg") >= 0) return 14.5;
    if (text.indexOf("13.5kg") >= 0 || text.indexOf("13.5 kg") >= 0) return 13.5;
    if (text.indexOf("12.5kg") >= 0 || text.indexOf("12.5 kg") >= 0) return 12.5;
    if (text.indexOf("11.5kg") >= 0 || text.indexOf("11.5 kg") >= 0) return 11.5;
    if (text.indexOf("10.5kg") >= 0 || text.indexOf("10.5 kg") >= 0) return 10.5;
    if (text.indexOf("9.5kg") >= 0  || text.indexOf("9.5 kg") >= 0)  return 9.5;
    if (text.indexOf("8.5kg") >= 0  || text.indexOf("8.5 kg") >= 0)  return 8.5;
    if (text.indexOf("7.5kg") >= 0  || text.indexOf("7.5 kg") >= 0)  return 7.5;
    if (text.indexOf("6.5kg") >= 0  || text.indexOf("6.5 kg") >= 0)  return 6.5;
    if (text.indexOf("5.5kg") >= 0  || text.indexOf("5.5 kg") >= 0)  return 5.5;
    return 0.0;
}

// Pounds → kg conversion helper. Common in some CHW notes from
// US-trained staff. 1 lb = 0.453592 kg; we approximate to 0.454.
function tryPounds(text: string): f64 {
    let p: i64 = 200;
    while (p >= 5) {
        const tag1 = "" + p + "lb";
        if (text.indexOf(tag1) >= 0) {
            return (p as f64) * 0.454;
        }
        const tag2 = "" + p + " lb";
        if (text.indexOf(tag2) >= 0) {
            return (p as f64) * 0.454;
        }
        p = p - 1;
    }
    return 0.0;
}

// Parse gestational age in weeks. Same substring approach as
// parseWeightKg — Abe v4.1 has no charCodeAt / parseI64. Covers the
// most common phrasings:
//   "8 weeks" / "8weeks" / "8 wk" / "8wks" (English)
//   "8 ibyumweru" / "ibyumweru 8" (Kinyarwanda — `ibyumweru` = weeks)
function tryWeeks(text: string, n: i64): bool {
    // English
    if (text.indexOf("" + n + " weeks")    >= 0) return true;
    if (text.indexOf("" + n + "weeks")     >= 0) return true;
    if (text.indexOf("" + n + " week")     >= 0) return true;
    if (text.indexOf("" + n + " wk")       >= 0) return true;
    if (text.indexOf("" + n + "wk")        >= 0) return true;
    // Kinyarwanda — ibyumweru (plural), icyumweru (singular,
    // less common in pregnancy notes but parsed for completeness)
    if (text.indexOf("" + n + " ibyumweru") >= 0) return true;
    if (text.indexOf("ibyumweru " + n)      >= 0) return true;
    if (text.indexOf("icyumweru cya " + n)  >= 0) return true;
    // Swahili — wiki (no plural/singular distinction)
    if (text.indexOf("wiki " + n)           >= 0) return true;
    if (text.indexOf("" + n + " wiki")      >= 0) return true;
    if (text.indexOf("wiki ya " + n)        >= 0) return true;  // "wiki ya 32" = "week 32"
    // French — semaine / semaines
    if (text.indexOf("" + n + " semaines")  >= 0) return true;
    if (text.indexOf("" + n + " semaine")   >= 0) return true;
    if (text.indexOf("semaine " + n)        >= 0) return true;
    return false;
}

// tryMonths — same shape as tryWeeks but for months phrasings across
// the four supported languages. Used as a fallback in
// parseGestationalWeeks when the message doesn't carry an explicit
// week count.
function tryMonths(text: string, n: i64): bool {
    // English
    if (text.indexOf("" + n + " months") >= 0) return true;
    if (text.indexOf("" + n + " month")  >= 0) return true;
    // Kinyarwanda — amezi (plural)
    if (text.indexOf("amezi " + n)        >= 0) return true;
    if (text.indexOf("" + n + " amezi")   >= 0) return true;
    // Swahili — miezi (plural), mwezi (singular)
    if (text.indexOf("miezi " + n)        >= 0) return true;
    if (text.indexOf("" + n + " miezi")   >= 0) return true;
    if (text.indexOf("mwezi " + n)        >= 0) return true;
    // French — mois (invariant in singular and plural)
    if (text.indexOf("" + n + " mois")    >= 0) return true;
    if (text.indexOf("" + n + "mois")     >= 0) return true;  // no-space form
    return false;
}

function parseGestationalMonths(text: string): i64 {
    // 1-10 — gestation in months is conventionally 1-9 (term);
    // 10 covers a marginal "10 months" phrasing that shows up in
    // post-term notes. Largest-first to avoid "8 months" being
    // shadowed by the substring "8" in "8 months ago".
    let n: i64 = 10;
    while (n >= 1) {
        if (tryMonths(text, n)) return n;
        n = n - 1;
    }
    return 0;
}

function parseGestationalWeeks(text: string): i64 {
    // 41 down to 1 — largest first so "25 weeks" doesn't match "5 weeks".
    let n: i64 = 41;
    while (n >= 1) {
        if (tryWeeks(text, n)) return n;
        n = n - 1;
    }
    // Fallback: months-based phrasing (FR "8 mois", SW "miezi 8",
    // RW "amezi 8", EN "8 months"). Convert via 4 weeks/month, which
    // aligns with the trimester boundaries in trimester_rules
    // (T1: weeks 1-13 / months 1-3; T2: weeks 14-26 / months 4-6;
    // T3: weeks 27-40 / months 7-9). "8 mois" → 32 weeks → T3.
    // This fallback handles month-expressed gestation (e.g. "8 mois").
    const months = parseGestationalMonths(text);
    if (months > 0) return months * 4;
    return 0;
}

// The trimester_rules SQL lookup lives inline in pregnancyHandler and the
// pregnancy reroute inside assessHandler.

function parseWeightKg(text: string): f64 {
    // Try ranges first — they're most specific.
    const r = tryRange(text);
    if (r > 0.0) return r;
    // Decimal half-kg values.
    const d = tryDecimalHalf(text);
    if (d > 0.0) return d;
    // Pounds (rare but real in mixed-training CHW notes).
    const p = tryPounds(text);
    if (p > 0.0) return p;
    // Largest first to avoid 25kg matching the substring 5kg.
    // Whole-number kg, largest-first. Largest-first matters: "25 kg"
    // contains the substring " 5 kg", so trying N=5 before N=25 would
    // mis-parse a 25 kg child as 5 kg. Range 1..200 covers neonates
    // through obese adults; the inner tryWeight builds "Nkg" / "N kg"
    // / "kg N" / "kg N" / "Nkg+" / "N+kg" forms. Earlier hand-enumerated
    // versions skipped 4, 13, 17, 19, 21, 23, 27, 29, 31, 32, 34, ...
    // which silently fell through to the substring of a smaller match
    // (e.g. "17kg" → 7 via the substring of " 7kg" inside "17kg").
    let n: i64 = 200;
    while (n >= 1) {
        if (tryWeight(text, n)) return n as f64;
        n = n - 1;
    }
    return 0.0;
}

// parseDistrict scans the (already-lowercased) body for any of the 30
// Rwandan district names — same body-parsing pattern as parseWeightKg
// and parseGestationalWeeks. Returns the canonical case-correct name
// or "" when no district is mentioned. Used by /v1/assess as a
// fallback when the caller didn't pass ?district= on the URL — CHW
// free-text notes typically embed the district inline ("Kayonza,
// child 22kg RDT+" or "district=Kayonza child..."). Substring match
// is safe here: no district name is a substring of another (checked
// across all 30), and the names are distinctive Kinyarwanda place
// names unlikely to appear inside ordinary clinical words. Length-
// DESC ordering is a defensive belt-and-braces in case future
// additions create a prefix collision.
function parseDistrict(textLower: string): string {
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT name FROM districts ORDER BY length(name) DESC, name");
    const n: i64 = dbResultRowCount(r);
    let found: string = "";
    for (let i: i64 = 0; i < n; i = i + 1) {
        const nm: string = dbResultGet(r, i, 0);
        const nmLower = nm.toLowerCase();
        if (textLower.indexOf(nmLower) >= 0) { found = nm; break; }
    }
    dbDisconnect(db);
    return found;
}

// ── PHI scrub ───────────────────────────────────────────────────────────────
// Deterministic substring scans (no regex codegen in v4.1). Each pass
// runs unconditionally so multiple PHI types in one text are all caught.
// Rwanda phone formats: +250 7XX (international), 250 7XX, 07XX or 7XX
// after a space — covered by checking the operator-prefix substrings.
// Dates: ISO and DD/MM forms common in CHW notes.
// GPS: latitude / longitude / coordinate keywords.

function scrubPHI(text: string): string {
    let result = text;
    // Email
    if (result.indexOf("@") >= 0)    result = result.replace("@", "[REDACTED@]");
    // Medical record numbers
    if (result.indexOf("MRN") >= 0)  result = result.replace("MRN", "[REDACTED]");
    if (result.indexOf("mrn") >= 0)  result = result.replace("mrn", "[REDACTED]");
    if (result.indexOf("ID:") >= 0)  result = result.replace("ID:", "[REDACTED]");
    if (result.indexOf("ID#") >= 0)  result = result.replace("ID#", "[REDACTED]");
    if (result.indexOf("Patient #") >= 0) result = result.replace("Patient #", "[REDACTED]");
    // Rwanda phones — international form
    if (result.indexOf("+250") >= 0) result = result.replace("+250", "[REDACTED+250]");
    if (result.indexOf("+25") >= 0)  result = result.replace("+25",  "[REDACTED+]");
    // Rwanda phones — local form (07XX). The leading zero plus a 7 is the
    // operator prefix; 4 such forms cover MTN / Airtel ranges.
    if (result.indexOf(" 0788") >= 0) result = result.replace(" 0788", " [REDACTED-PHONE]");
    if (result.indexOf(" 0789") >= 0) result = result.replace(" 0789", " [REDACTED-PHONE]");
    if (result.indexOf(" 0782") >= 0) result = result.replace(" 0782", " [REDACTED-PHONE]");
    if (result.indexOf(" 0783") >= 0) result = result.replace(" 0783", " [REDACTED-PHONE]");
    if (result.indexOf(" 0784") >= 0) result = result.replace(" 0784", " [REDACTED-PHONE]");
    if (result.indexOf(" 0785") >= 0) result = result.replace(" 0785", " [REDACTED-PHONE]");
    if (result.indexOf(" 0786") >= 0) result = result.replace(" 0786", " [REDACTED-PHONE]");
    if (result.indexOf(" 0787") >= 0) result = result.replace(" 0787", " [REDACTED-PHONE]");
    if (result.indexOf(" 0720") >= 0) result = result.replace(" 0720", " [REDACTED-PHONE]");
    if (result.indexOf(" 0722") >= 0) result = result.replace(" 0722", " [REDACTED-PHONE]");
    if (result.indexOf(" 0723") >= 0) result = result.replace(" 0723", " [REDACTED-PHONE]");
    if (result.indexOf(" 0725") >= 0) result = result.replace(" 0725", " [REDACTED-PHONE]");
    if (result.indexOf(" 0728") >= 0) result = result.replace(" 0728", " [REDACTED-PHONE]");
    if (result.indexOf(" 0729") >= 0) result = result.replace(" 0729", " [REDACTED-PHONE]");
    // Date / DOB markers
    if (result.indexOf("DOB:") >= 0)        result = result.replace("DOB:", "[REDACTED-DOB:]");
    if (result.indexOf("DOB ") >= 0)        result = result.replace("DOB ", "[REDACTED-DOB] ");
    if (result.indexOf("born ") >= 0)       result = result.replace("born ", "[REDACTED-DOB] ");
    if (result.indexOf("d.o.b.") >= 0)      result = result.replace("d.o.b.", "[REDACTED-DOB]");
    // ISO years in the obvious DOB range — narrow scan to avoid false
    // positives on RBC year references like "RBC 2024".
    if (result.indexOf("19") >= 0) {
        // 19xx patterns: scan a small window. We replace the most common
        // birth-year prefixes; missed years are scrubbed by the operator
        // when they review the audit log.
        if (result.indexOf("1980") >= 0) result = result.replace("1980", "[REDACTED-YEAR]");
        if (result.indexOf("1985") >= 0) result = result.replace("1985", "[REDACTED-YEAR]");
        if (result.indexOf("1990") >= 0) result = result.replace("1990", "[REDACTED-YEAR]");
        if (result.indexOf("1995") >= 0) result = result.replace("1995", "[REDACTED-YEAR]");
    }
    // GPS / location pinpoint markers (CHW apps occasionally embed these).
    if (result.indexOf("lat:") >= 0)        result = result.replace("lat:", "[REDACTED-LAT:]");
    if (result.indexOf("lon:") >= 0)        result = result.replace("lon:", "[REDACTED-LON:]");
    if (result.indexOf("latitude") >= 0)    result = result.replace("latitude", "[REDACTED-LATITUDE]");
    if (result.indexOf("longitude") >= 0)   result = result.replace("longitude", "[REDACTED-LONGITUDE]");
    if (result.indexOf("gps:") >= 0)        result = result.replace("gps:", "[REDACTED-GPS:]");
    return result;
}

// ── LLM proxy with RBC-2024-locked system prompt ────────────────────────────

function llmSystemPrompt(): string {
    return "You are a clinical assistant for community health workers in Rwanda, "
         + "operating under Rwanda Biomedical Centre 2024 malaria guidelines. "
         + "Hard rules you MUST NOT break: "
         + "(1) Severe malaria signs (convulsions, unable to wake / drink / "
         +     "breastfeed, persistent vomiting, AVPU drop) require immediate "
         +     "referral and pre-referral rectal artesunate if available — "
         +     "never home AL. "
         + "(2) First-trimester pregnancy: quinine + clindamycin only; AL is "
         +     "contraindicated. Second/third trimester may use AL. "
         + "(3) Treatment failure on day 3 post-AL: refer to district hospital; "
         +     "never repeat AL. "
         + "(4) AL weight bands per RBC 2024: 5-14kg=1tab, 15-24kg=2tabs, "
         +     "25-34kg=3tabs, >=35kg=4tabs, BD x 3 days with food. "
         + "(5) Respond in the language indicated at the start of the prompt: "
         +     "[EN] means English; [RW] means KINYARWANDA (the Rwandan "
         +     "Bantu language — NOT Romanian, NOT Swahili, NOT Kirundi). "
         +     "If the tag is [RW] respond entirely in Kinyarwanda — never "
         +     "switch to Romanian, Swahili, or any other language. "
         + "(6) Do not invent patient details. If specific information is "
         +     "missing from the prompt, ask the CHW to provide it. Do NOT "
         +     "fill in vitals, ages, or weights you were not given. "
         + "(7) Keep responses CONCISE. Target 400 tokens or fewer. "
         +     "Use short bullet points; avoid extensive markdown tables, "
         +     "headers deeper than h3, or repeating the same advice in "
         +     "multiple sections. CHWs need quick answers, not multi-page "
         +     "guides.";
}

function langTag(lang: string): string {
    if (lang == "rw") return "[RW]";
    return "[EN]";
}

// ── JSON request body helper ────────────────────────────────────────────────
// Optional structured input alternative to free-text. Callers can POST
// a JSON body like
//   {"weightKg":22, "rdtPositive":true, "dangerSigns":["convulsions"]}
// and the deterministic parsers will see the same signal as if the CHW
// had written "22kg RDT positive convulsions" in free text.
//
// Implementation: detect a leading "{" in the trimmed body, then scan
// for known keys with substring extraction (Abe v4.1 has no full JSON
// navigation API beyond abe_json_parse which returns an opaque ptr).
// We synthesise a free-text shadow string that the existing
// dangerHitCount / parseWeightKg / etc. consume — keeps the parsing
// pipeline unchanged.

function looksLikeJson(text: string): bool {
    const t = text.trim();
    if (t.length() == 0) return false;
    return t.indexOf("{") == 0;
}

// Extract a numeric value from `"key":N`. Tries common spacings.
// Returns 0 when the field is missing — caller treats as "not provided".
function jsonExtractNumberValueRaw(json: string, key: string): string {
    const opener1 = "\"" + key + "\":";
    let start = json.indexOf(opener1);
    if (start < 0) {
        const opener2 = "\"" + key + "\" :";
        start = json.indexOf(opener2);
        if (start < 0) return "";
    }
    // Slice everything after the colon and trim leading spaces. Number
    // ends at first non-digit / non-decimal-dot.
    const tail = json.substring(start, json.length());
    const colon = tail.indexOf(":");
    if (colon < 0) return "";
    const after = tail.substring(colon + 1, tail.length()).trim();
    // Walk forward collecting digits + dots until we hit a delimiter.
    let i: i64 = 0;
    let buf = "";
    const lim = after.length();
    while (i < lim) {
        const ch = after.substring(i, i + 1);
        if (ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4"
         || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9"
         || ch == ".") {
            buf = buf + ch;
            i = i + 1;
        } else {
            i = lim;
        }
    }
    return buf;
}

// Extract a boolean: true when the value token after the key is `true`.
// Mirrors jsonExtractNumberValueRaw: find the key, advance past the colon,
// skip leading spaces, and test the value token. Returns false otherwise.
function jsonExtractBool(json: string, key: string): bool {
    const opener1 = "\"" + key + "\":";
    let start = json.indexOf(opener1);
    if (start < 0) {
        const opener2 = "\"" + key + "\" :";
        start = json.indexOf(opener2);
        if (start < 0) return false;
    }
    const tail = json.substring(start, json.length());
    const colon = tail.indexOf(":");
    if (colon < 0) return false;
    const after = tail.substring(colon + 1, tail.length()).trim();
    return after.indexOf("true") == 0;
}

// Synthesise a free-text shadow from a JSON body so the existing
// downstream parsers (parseWeightKg, parseGestationalWeeks,
// dangerHitCount, isPregnant, etc.) can run unchanged. We simply append
// the structured fields' string forms; order doesn't matter because the
// parsers all use indexOf.
function jsonToShadowText(json: string, original: string): string {
    let out = original + " ";
    const wkg  = jsonExtractNumberValueRaw(json, "weightKg");
    const wks  = jsonExtractNumberValueRaw(json, "weeksGestation");
    const wks2 = jsonExtractNumberValueRaw(json, "weeks");
    if (wkg.length() > 0)  out = out + " " + wkg + "kg";
    if (wks.length() > 0)  out = out + " " + wks + " weeks";
    else if (wks2.length() > 0) out = out + " " + wks2 + " weeks";
    if (jsonExtractBool(json, "rdtPositive")) out = out + " RDT positive";
    if (jsonExtractBool(json, "pregnant"))    out = out + " pregnant";
    if (jsonExtractBool(json, "convulsions")) out = out + " convulsions";
    if (jsonExtractBool(json, "cannotDrink")) out = out + " cannot drink";
    if (jsonExtractBool(json, "cannotBreastfeed")) out = out + " cannot breastfeed";
    if (jsonExtractBool(json, "vomitingEverything")) out = out + " vomiting everything";
    if (jsonExtractBool(json, "darkUrine")) out = out + " dark urine";
    if (jsonExtractBool(json, "jaundice")) out = out + " jaundice";
    if (jsonExtractBool(json, "lethargic")) out = out + " lethargic";
    if (jsonExtractBool(json, "treatmentFailure")) out = out + " day 3 still febrile AL";
    return out;
}

// Normalise a request body. If JSON, expand it into a shadow free-text
// equivalent and concatenate with anything else. Otherwise return as-is.
function normaliseBody(raw: string): string {
    if (looksLikeJson(raw)) return jsonToShadowText(raw, raw);
    return raw;
}

// ── Audit log persistence ───────────────────────────────────────────────────
// Append-only file at /tmp/malariachat-audit.jsonl. Each request writes
// one line with timestamp, audit ID, task, language, and a short
// summary string. We do read-modify-write because the runtime has no
// appendFile primitive — fine for demo scale; concurrent writes could
// drop entries under load, which is documented but acceptable. Real
// production would want either a runtime appendFile primitive or
// per-process exclusive write locks.

function auditLogPath(): string { return "/tmp/malariachat-audit.jsonl"; }

function auditAppend(auditId: string, task: string, lang: string, summary: string): void {
    const line = "{"
        + "\"ts\":"      + time_us() + ","
        + "\"id\":\""    + jsonEscape(auditId) + "\","
        + "\"task\":\""  + jsonEscape(task) + "\","
        + "\"lang\":\""  + jsonEscape(lang) + "\","
        + "\"sum\":\""   + jsonEscape(summary) + "\""
        + "}\n";
    const existing = readFileSync(auditLogPath(), "utf8");
    writeFile(auditLogPath(), existing + line);
}

// ── Explain prose ───────────────────────────────────────────────────────────
// Read-only protocol-transparency endpoints. The CHW asks "why this
// dose?" or "why quinine in 1st trimester?" and gets back the RBC 2024
// rule plus the table that produced it. Pure deterministic content —
// no LLM, no external lookups.

function alBandTableEn(): string {
    return "RBC 2024 AL weight-band table:\n"
         + "  5-14 kg  = 1 tablet  BD x 3 days with food\n"
         + "  15-24 kg = 2 tablets BD x 3 days with food\n"
         + "  25-34 kg = 3 tablets BD x 3 days with food\n"
         + "  >=35 kg  = 4 tablets BD x 3 days with food\n"
         + "Under 5 kg: refer; AL is not first-line at this weight.\n"
         + "1st-trimester pregnancy: AL contraindicated — use quinine + clindamycin.\n"
         + "Day-3 treatment failure: refer; do NOT repeat AL.";
}

function alBandTableRw(): string {
    return "Imbonerahamwe ya RBC 2024 y'ingano ya AL hakurikijwe ibiro:\n\n"
         + "* 5-14 kg = ikinini 1 kabiri ku munsi (BD) mu minsi 3, gifatanywe n'ibiryo\n"
         + "* 15-24 kg = ibinini 2 kabiri ku munsi (BD) mu minsi 3, bifatanywe n'ibiryo\n"
         + "* 25-34 kg = ibinini 3 kabiri ku munsi (BD) mu minsi 3, bifatanywe n'ibiryo\n"
         + "* >=35 kg = ibinini 4 kabiri ku munsi (BD) mu minsi 3, bifatanywe n'ibiryo\n\n"
         + "Abari munsi ya 5 kg: boherezwe kwa muganga; AL ntabwo ariwo muti wa mbere ku bafite ibi biro.\n\n"
         + "Abagore batwite mu gihembwe cya mbere: AL ntiyemewe — hakoreshejwe quinine hamwe na clindamycin.\n\n"
         + "Kunanirwa kuvura ku munsi wa 3: ohereza umurwayi kwa muganga; ntusubiremo AL.";
}

function trimesterTableEn(): string {
    return "RBC 2024 trimester table for malaria treatment:\n"
         + "  1-13 weeks (1st trimester): quinine 10mg/kg + clindamycin 5mg/kg, "
         + "TID x 7 days. AL CONTRAINDICATED.\n"
         + "  14-26 weeks (2nd trimester): AL by weight band (see /v1/explain-dose).\n"
         + "  27+ weeks (3rd trimester): AL by weight band.\n"
         + "All trimesters: severe-malaria signs require immediate referral and "
         + "pre-referral rectal artesunate where available, regardless of trimester.";
}

function trimesterTableRw(): string {
    return "Imbonerahamwe ya RBC 2024 mu kuvura malariya abagore batwite ukurikije igihembwe bagezemo:\n\n"
         + "* Ibyumweru 1-13 (igihembwe cya mbere): quinine 10mg/kg hamwe na clindamycin 5mg/kg, gatatu ku munsi (TID) mu minsi 7. AL NTIYEMEWE.\n"
         + "* Ibyumweru 14-26 (igihembwe cya kabiri): AL hakurikijwe ibiro (reba imbonerahamwe ya doze aha haruguru).\n"
         + "* Ibyumweru 27 kuzamura (igihembwe cya gatatu): AL hakurikijwe ibiro.\n\n"
         + "Mu bihembwe byose byo gutwita: ibimenyetso bya malariya ikabije bisaba kohereza umurwayi kwa muganga ako kanya no gutanga rectal artesunate mbere yo kumwohereza aho iboneka, hatitawe ku gihembwe cyo gutwita agezemo.";
}

// ── Handlers ────────────────────────────────────────────────────────────────

function homeHandler(req: ptr, res: ptr): void {
    const html = readFileSync("./ui/index.html", "utf8");
    if (html.length() == 0) {
        response_status(res, 500);
        response_text(res,
            "UI file ./ui/index.html not found. "
            + "Run the daemon from the project root directory.");
        return;
    }
    response_status(res, 200);
    response_html(res, html);
}

function templateVersion(): string { return "rbc-2024-v1"; }
function severeKeywordCount(): i64 {
    // Live count from danger_signs (replaces the previous hand-maintained "60").
    const db = dbConnect("dbname=malariachat");
    const r  = dbQuery(db,
        "SELECT count(*) FROM danger_signs WHERE protocol_id = 'RBC-2024'");
    const s: string = dbResultGet(r, 0, 0);
    dbDisconnect(db);
    return Number(s) as i64;
}

function totalRequests(): i64 {
    return counter_get(slotAssess())
         + counter_get(slotDanger())
         + counter_get(slotPregnancy())
         + counter_get(slotPrevention())
         + counter_get(slotReport())
         + counter_get(slotFirstLine())
         + counter_get(slotIptp())
         + counter_get(slotVaccines())
         + counter_get(slotChat());
}

function healthHandler(req: ptr, res: ptr): void {
    const auditId = generateAuditId();
    const body = "{"
        + "\"status\":\"ok\","
        + "\"model\":\""           + jsonEscape(modelLabel())     + "\","
        + "\"version\":\""         + jsonEscape(apiVersion())     + "\","
        + "\"protocol\":\"RBC 2024\","
        + "\"templateVersion\":\"" + templateVersion()            + "\","
        + "\"languages\":[\"en\",\"rw\"],"
        + "\"offlineCapable\":false,"
        + "\"offlineNote\":\"Free-form chat uses an online LLM backend, so the service is not offline-capable while that backend is active. A self-hosted/in-process backend would restore offline capability.\","
        + "\"endpoints\":["
        +   "\"GET /v1/health\","
        +   "\"GET /v1/metrics\","
        +   "\"GET /v1/audit-log\","
        +   "\"GET /v1/explain-dose\","
        +   "\"GET /v1/explain-trimester\","
        +   "\"GET /v1/first-line\","
        +   "\"GET /v1/iptp\","
        +   "\"GET /v1/vaccines\","
        +   "\"POST /v1/assess\","
        +   "\"POST /v1/danger\","
        +   "\"POST /v1/pregnancy\","
        +   "\"POST /v1/prevention\","
        +   "\"POST /v1/report\","
        +   "\"POST /v1/chat\""
        + "],"
        + "\"safety\":{"
        +   "\"severeKeywordCount\":" + severeKeywordCount() + ","
        +   "\"deterministicAnchors\":[\"verifiedDose\",\"verifiedTrimester\",\"severeGate\",\"treatmentFailure\",\"pregnancyReroute\"]"
        + "},"
        + "\"counters\":{"
        +   "\"totalRequests\":"      + totalRequests() + ","
        +   "\"severeGateTriggered\":" + counter_get(slotSevereGate())
        + "},"
        + "\"clockMicros\":"  + time_us() + ","
        + "\"auditId\":\""    + auditId   + "\""
        + "}";
    jsonResponse(res, 200, auditId, body);
}

// Turn the newline-delimited JSONL log into a JSON array body: split on
// "\n", drop empty lines, and join the (already-JSON) entries with ",".
// String.replace only hits the first match, so we walk manually.
function auditEntriesJson(log: string): string {
    let out = "";
    let rest = log;
    let nl = rest.indexOf("\n");
    while (nl >= 0) {
        const line = rest.substring(0, nl).trim();
        if (line.length() > 0) {
            if (out.length() > 0) out = out + ",";
            out = out + line;
        }
        rest = rest.substring(nl + 1, rest.length());
        nl = rest.indexOf("\n");
    }
    const last = rest.trim();
    if (last.length() > 0) {
        if (out.length() > 0) out = out + ",";
        out = out + last;
    }
    return out;
}

function auditLogHandler(req: ptr, res: ptr): void {
    const auditId = generateAuditId();
    const log = readFileSync(auditLogPath(), "utf8");
    const body = "{"
        + "\"path\":\""  + jsonEscape(auditLogPath()) + "\","
        + "\"size\":"    + log.length() + ","
        + "\"entries\":[" + auditEntriesJson(log)
        + "],"
        + "\"auditId\":\"" + jsonEscape(auditId) + "\""
        + "}";
    jsonResponse(res, 200, auditId, body);
}

